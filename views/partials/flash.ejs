<%
  const _success = (typeof success !== 'undefined' && success) ? success : [];
  const _error   = (typeof error   !== 'undefined' && error)   ? error   : [];
  const _warning = (typeof warning !== 'undefined' && warning) ? warning : [];
  const _info    = (typeof info    !== 'undefined' && info)    ? info    : [];
  const _hasAny  = _success.length || _error.length || _warning.length || _info.length;
%>
<% if (_hasAny) { %>
<div class="flash-container" aria-live="polite">

  <% _success.forEach(msg => { %>
    <div class="flash flash-success" role="alert">
      <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
      <span><%= msg %></span>
      <button class="flash-close" aria-label="Close">
        <i data-lucide="x" class="w-4 h-4"></i>
      </button>
    </div>
  <% }) %>

  <% _error.forEach(msg => { %>
    <div class="flash flash-error" role="alert">
      <i data-lucide="x-circle" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
      <span><%= msg %></span>
      <button class="flash-close" aria-label="Close">
        <i data-lucide="x" class="w-4 h-4"></i>
      </button>
    </div>
  <% }) %>

  <% _warning.forEach(msg => { %>
    <div class="flash flash-warning" role="alert">
      <i data-lucide="alert-triangle" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
      <span><%= msg %></span>
      <button class="flash-close" aria-label="Close">
        <i data-lucide="x" class="w-4 h-4"></i>
      </button>
    </div>
  <% }) %>

  <% _info.forEach(msg => { %>
    <div class="flash flash-info" role="alert">
      <i data-lucide="info" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
      <span><%= msg %></span>
      <button class="flash-close" aria-label="Close">
        <i data-lucide="x" class="w-4 h-4"></i>
      </button>
    </div>
  <% }) %>

</div>
<% } %>
