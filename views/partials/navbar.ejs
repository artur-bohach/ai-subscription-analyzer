<nav class="navbar">
  <div class="nav-inner">

    <!-- Logo -->
    <a href="/" class="nav-logo">
      <div class="nav-logo-icon">S</div>
      <span>Sub<span style="color:var(--neon)">Tracker</span></span>
    </a>

    <!-- Desktop Nav Links -->
    <div class="nav-links hidden md:flex">
      <% if (isAuthenticated) { %>
        <a href="/dashboard"     class="nav-link <%= currentPath === '/dashboard' ? 'active' : '' %>">
          <i data-lucide="layout-dashboard" class="w-3.5 h-3.5"></i> Dashboard
        </a>
        <a href="/subscriptions" class="nav-link <%= currentPath.startsWith('/subscriptions') ? 'active' : '' %>">
          <i data-lucide="credit-card" class="w-3.5 h-3.5"></i> Subscriptions
        </a>
        <% if (isAdmin) { %>
          <a href="/admin" class="nav-link <%= currentPath.startsWith('/admin') ? 'active' : '' %>">
            <i data-lucide="shield" class="w-3.5 h-3.5"></i> Admin
          </a>
        <% } %>
      <% } else { %>
        <a href="/"        class="nav-link <%= currentPath === '/' ? 'active' : '' %>">
          <i data-lucide="home" class="w-3.5 h-3.5"></i> Home
        </a>
        <a href="/about"   class="nav-link <%= currentPath === '/about' ? 'active' : '' %>">
          <i data-lucide="info" class="w-3.5 h-3.5"></i> About
        </a>
        <a href="/contact" class="nav-link <%= currentPath === '/contact' ? 'active' : '' %>">
          <i data-lucide="mail" class="w-3.5 h-3.5"></i> Contact
        </a>
      <% } %>
    </div>

    <!-- Desktop Right Actions -->
    <div class="nav-right hidden md:flex">
      <% if (isAuthenticated) { %>
        <div class="nav-dropdown-wrap" id="user-dropdown-wrap">
          <button
            id="user-dropdown-btn"
            class="flex items-center gap-2 cursor-pointer bg-transparent border-0 p-0"
            aria-haspopup="true"
            aria-expanded="false"
          >
            <div class="nav-avatar" title="<%= currentUser.username %>">
              <span><%= currentUser.username.charAt(0).toUpperCase() %></span>
            </div>
            <span class="text-sm font-medium hidden lg:inline" style="color:var(--muted)"><%= currentUser.username %></span>
            <% if (isAdmin) { %><span class="nav-badge">Admin</span><% } %>
            <i data-lucide="chevron-down" class="w-3.5 h-3.5" style="color:var(--muted2)"></i>
          </button>

          <div class="nav-dropdown-menu" id="user-dropdown-menu">
            <div class="nav-dropdown-header">
              <p class="text-sm font-medium" style="color:var(--text)"><%= currentUser.username %></p>
              <p class="text-xs truncate" style="color:var(--muted)"><%= currentUser.email %></p>
            </div>
            <a href="/subscriptions" class="nav-dropdown-item">
              <i data-lucide="credit-card" class="w-4 h-4"></i> My Subscriptions
            </a>
            <a href="/subscriptions/new" class="nav-dropdown-item">
              <i data-lucide="plus-circle" class="w-4 h-4"></i> Add Subscription
            </a>
            <div class="nav-dropdown-divider"></div>
            <a href="/profile" class="nav-dropdown-item">
              <i data-lucide="user" class="w-4 h-4"></i> Profile & Settings
            </a>
            <div class="nav-dropdown-divider"></div>
            <form action="/logout" method="POST" class="m-0">
              <button type="submit" class="nav-dropdown-item nav-dropdown-item-danger w-full text-left">
                <i data-lucide="log-out" class="w-4 h-4"></i> Sign Out
              </button>
            </form>
          </div>
        </div>
      <% } else { %>
        <a href="/login"    class="btn-ghost text-sm">Sign In</a>
        <a href="/register" class="btn-primary text-sm">Sign Up</a>
      <% } %>
    </div>

    <!-- Mobile Menu Button -->
    <button id="menu-btn" class="md:hidden p-2 rounded-lg" style="color:var(--muted);background:transparent;border:0;cursor:pointer" aria-label="Toggle menu" aria-expanded="false">
      <i data-lucide="menu" class="w-5 h-5"></i>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu">
    <% if (isAuthenticated) { %>
      <a href="/dashboard"     class="nav-link <%= currentPath === '/dashboard' ? 'active' : '' %>">
        <i data-lucide="layout-dashboard" class="w-4 h-4"></i> Dashboard
      </a>
      <a href="/subscriptions" class="nav-link <%= currentPath.startsWith('/subscriptions') ? 'active' : '' %>">
        <i data-lucide="credit-card" class="w-4 h-4"></i> Subscriptions
      </a>
      <a href="/subscriptions/new" class="nav-link">
        <i data-lucide="plus-circle" class="w-4 h-4"></i> Add Subscription
      </a>
      <% if (isAdmin) { %>
        <a href="/admin" class="nav-link <%= currentPath.startsWith('/admin') ? 'active' : '' %>">
          <i data-lucide="shield" class="w-4 h-4"></i> Admin
        </a>
      <% } %>
      <div style="padding-top:10px;border-top:1px solid var(--border);margin-top:6px;display:flex;flex-direction:column;gap:8px">
        <div class="flex items-center gap-2.5 px-2">
          <div class="nav-avatar"><span><%= currentUser.username.charAt(0).toUpperCase() %></span></div>
          <div>
            <p class="text-sm font-medium" style="color:var(--text)"><%= currentUser.username %></p>
            <p class="text-xs" style="color:var(--muted)"><%= currentUser.email %></p>
          </div>
          <% if (isAdmin) { %><span class="nav-badge ml-auto">Admin</span><% } %>
        </div>
        <a href="/profile" class="btn-ghost text-sm justify-center">
          <i data-lucide="user" class="w-3.5 h-3.5"></i> Profile
        </a>
        <form action="/logout" method="POST" class="m-0">
          <button type="submit" class="btn-ghost text-sm w-full justify-center" style="border-color:var(--danger);color:var(--danger)">
            <i data-lucide="log-out" class="w-3.5 h-3.5"></i> Sign Out
          </button>
        </form>
      </div>
    <% } else { %>
      <a href="/"        class="nav-link <%= currentPath === '/' ? 'active' : '' %>"><i data-lucide="home" class="w-4 h-4"></i> Home</a>
      <a href="/about"   class="nav-link <%= currentPath === '/about' ? 'active' : '' %>"><i data-lucide="info" class="w-4 h-4"></i> About</a>
      <a href="/contact" class="nav-link <%= currentPath === '/contact' ? 'active' : '' %>"><i data-lucide="mail" class="w-4 h-4"></i> Contact</a>
      <div style="padding-top:10px;border-top:1px solid var(--border);margin-top:6px;display:flex;flex-direction:column;gap:8px">
        <a href="/login"    class="btn-ghost text-sm justify-center">Sign In</a>
        <a href="/register" class="btn-primary text-sm justify-center">Sign Up</a>
      </div>
    <% } %>
  </div>
</nav>
