<nav class="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-purple-500 to-blue-500 flex items-center justify-center flex-shrink-0 group-hover:shadow-lg group-hover:shadow-purple-500/40 transition-shadow">
          <i data-lucide="layers" class="w-4 h-4 text-white"></i>
        </div>
        <span class="font-bold text-base text-white">
          Sub<span class="gradient-text">Tracker</span>
        </span>
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden md:flex items-center gap-1">
        <% if (isAuthenticated) { %>
          <!-- Logged-in nav -->
          <a href="/subscriptions" class="nav-link <%= currentPath.startsWith('/subscriptions') ? 'active' : '' %>">
            <i data-lucide="credit-card" class="w-3.5 h-3.5"></i> Subscriptions
          </a>
          <% if (isAdmin) { %>
            <a href="/admin" class="nav-link <%= currentPath.startsWith('/admin') ? 'active' : '' %>">
              <i data-lucide="shield" class="w-3.5 h-3.5"></i> Admin Panel
            </a>
          <% } %>
        <% } else { %>
          <!-- Guest nav -->
          <a href="/"        class="nav-link <%= currentPath === '/' ? 'active' : '' %>">
            <i data-lucide="home" class="w-3.5 h-3.5"></i> Home
          </a>
          <a href="/about"   class="nav-link <%= currentPath === '/about' ? 'active' : '' %>">
            <i data-lucide="info" class="w-3.5 h-3.5"></i> About
          </a>
          <a href="/contact" class="nav-link <%= currentPath === '/contact' ? 'active' : '' %>">
            <i data-lucide="mail" class="w-3.5 h-3.5"></i> Contact
          </a>
        <% } %>
      </div>

      <!-- Desktop Right Actions -->
      <div class="hidden md:flex items-center gap-3">
        <% if (isAuthenticated) { %>
          <!-- User Dropdown -->
          <div class="user-dropdown-wrap" id="user-dropdown-wrap">
            <button
              id="user-dropdown-btn"
              class="user-dropdown-trigger"
              aria-haspopup="true"
              aria-expanded="false"
            >
              <div class="user-avatar">
                <span><%= currentUser.username.charAt(0).toUpperCase() %></span>
              </div>
              <span class="text-sm text-slate-300 font-medium"><%= currentUser.username %></span>
              <% if (isAdmin) { %>
                <span class="badge-admin">Admin</span>
              <% } %>
              <i data-lucide="chevron-down" class="w-3.5 h-3.5 text-slate-400 dropdown-chevron"></i>
            </button>

            <!-- Dropdown Menu -->
            <div class="user-dropdown-menu" id="user-dropdown-menu">
              <!-- User info header -->
              <div class="dropdown-header">
                <p class="text-sm font-medium text-white"><%= currentUser.username %></p>
                <p class="text-xs text-slate-400 truncate"><%= currentUser.email %></p>
              </div>

              <div class="dropdown-divider"></div>

              <a href="/subscriptions" class="dropdown-item">
                <i data-lucide="credit-card" class="w-4 h-4"></i> My Subscriptions
              </a>
              <a href="/subscriptions/new" class="dropdown-item">
                <i data-lucide="plus-circle" class="w-4 h-4"></i> Add Subscription
              </a>

              <div class="dropdown-divider"></div>

              <a href="#" class="dropdown-item" onclick="return false;">
                <i data-lucide="user" class="w-4 h-4"></i> Profile
                <span class="dropdown-badge-soon">Soon</span>
              </a>
              <a href="#" class="dropdown-item" onclick="return false;">
                <i data-lucide="settings" class="w-4 h-4"></i> Settings
                <span class="dropdown-badge-soon">Soon</span>
              </a>

              <div class="dropdown-divider"></div>

              <form action="/logout" method="POST" class="m-0">
                <button type="submit" class="dropdown-item dropdown-item-danger w-full text-left">
                  <i data-lucide="log-out" class="w-4 h-4"></i> Sign Out
                </button>
              </form>
            </div>
          </div>
        <% } else { %>
          <a href="/login" class="btn-ghost text-sm py-1.5 px-4">
            <i data-lucide="log-in" class="w-3.5 h-3.5"></i> Sign In
          </a>
          <a href="/register" class="btn-gradient text-sm py-1.5 px-4">
            <i data-lucide="user-plus" class="w-3.5 h-3.5"></i> Sign Up
          </a>
        <% } %>
      </div>

      <!-- Mobile Menu Button -->
      <button id="menu-btn" class="md:hidden p-2 rounded-lg text-slate-400 hover:text-white hover:bg-white/10 transition-colors" aria-label="Toggle menu">
        <i data-lucide="menu" class="w-5 h-5"></i>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu">
      <% if (isAuthenticated) { %>
        <a href="/subscriptions" class="nav-link <%= currentPath.startsWith('/subscriptions') ? 'active' : '' %>">
          <i data-lucide="credit-card" class="w-4 h-4"></i> Subscriptions
        </a>
        <a href="/subscriptions/new" class="nav-link">
          <i data-lucide="plus-circle" class="w-4 h-4"></i> Add Subscription
        </a>
        <% if (isAdmin) { %>
          <a href="/admin" class="nav-link <%= currentPath.startsWith('/admin') ? 'active' : '' %>">
            <i data-lucide="shield" class="w-4 h-4"></i> Admin Panel
          </a>
        <% } %>
        <div class="pt-2 border-t border-white/10 mt-2 flex flex-col gap-2">
          <div class="flex items-center gap-2.5 px-2 py-1.5">
            <div class="user-avatar user-avatar-sm">
              <span><%= currentUser.username.charAt(0).toUpperCase() %></span>
            </div>
            <div>
              <p class="text-sm text-white font-medium leading-tight"><%= currentUser.username %></p>
              <p class="text-xs text-slate-500 leading-tight"><%= currentUser.email %></p>
            </div>
            <% if (isAdmin) { %>
              <span class="badge-admin ml-auto">Admin</span>
            <% } %>
          </div>
          <form action="/logout" method="POST" class="m-0">
            <button type="submit" class="btn-ghost text-sm w-full justify-center">
              <i data-lucide="log-out" class="w-3.5 h-3.5"></i> Sign Out
            </button>
          </form>
        </div>
      <% } else { %>
        <a href="/"        class="nav-link <%= currentPath === '/' ? 'active' : '' %>">
          <i data-lucide="home" class="w-4 h-4"></i> Home
        </a>
        <a href="/about"   class="nav-link <%= currentPath === '/about' ? 'active' : '' %>">
          <i data-lucide="info" class="w-4 h-4"></i> About
        </a>
        <a href="/contact" class="nav-link <%= currentPath === '/contact' ? 'active' : '' %>">
          <i data-lucide="mail" class="w-4 h-4"></i> Contact
        </a>
        <div class="pt-2 border-t border-white/10 mt-2 flex flex-col gap-2">
          <a href="/login" class="btn-ghost text-sm justify-center">
            <i data-lucide="log-in" class="w-3.5 h-3.5"></i> Sign In
          </a>
          <a href="/register" class="btn-gradient text-sm justify-center">
            <i data-lucide="user-plus" class="w-3.5 h-3.5"></i> Sign Up
          </a>
        </div>
      <% } %>
    </div>
  </div>
</nav>
