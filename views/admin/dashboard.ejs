<div class="p-6 lg:p-8 space-y-8">

  <!-- Page header -->
  <div>
    <h1 class="text-2xl font-bold text-white">Dashboard</h1>
    <p class="text-sm text-slate-500 mt-1">Platform overview and key metrics</p>
  </div>

  <!-- ── Stat Cards ─────────────────────────────────────────────────────────── -->
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">

    <!-- Total Users -->
    <div class="admin-stat-card">
      <div class="flex items-start justify-between">
        <div>
          <p class="admin-stat-label">Total Users</p>
          <p class="admin-stat-value"><%= stats.totalUsers %></p>
          <p class="admin-stat-sub">
            <span class="text-emerald-400">+<%= stats.newUsersThisWeek %></span> this week
          </p>
        </div>
        <div class="admin-stat-icon" style="background:rgba(249,115,22,0.15);color:#fb923c;">
          <i data-lucide="users" class="w-5 h-5"></i>
        </div>
      </div>
    </div>

    <!-- Total Subscriptions -->
    <div class="admin-stat-card">
      <div class="flex items-start justify-between">
        <div>
          <p class="admin-stat-label">Total Subscriptions</p>
          <p class="admin-stat-value"><%= stats.totalSubs %></p>
          <p class="admin-stat-sub">across all users</p>
        </div>
        <div class="admin-stat-icon" style="background:rgba(139,92,246,0.15);color:#a78bfa;">
          <i data-lucide="credit-card" class="w-5 h-5"></i>
        </div>
      </div>
    </div>

    <!-- Monthly Revenue -->
    <div class="admin-stat-card">
      <div class="flex items-start justify-between">
        <div>
          <p class="admin-stat-label">Monthly Revenue</p>
          <p class="admin-stat-value">€<%= stats.totalMonthlyRevenue.toFixed(2) %></p>
          <p class="admin-stat-sub">active subscriptions</p>
        </div>
        <div class="admin-stat-icon" style="background:rgba(16,185,129,0.15);color:#34d399;">
          <i data-lucide="dollar-sign" class="w-5 h-5"></i>
        </div>
      </div>
    </div>

    <!-- Avg per User -->
    <div class="admin-stat-card">
      <div class="flex items-start justify-between">
        <div>
          <p class="admin-stat-label">Average per User</p>
          <p class="admin-stat-value">€<%= stats.avgPerUser.toFixed(2) %></p>
          <p class="admin-stat-sub">monthly spend</p>
        </div>
        <div class="admin-stat-icon" style="background:rgba(59,130,246,0.15);color:#60a5fa;">
          <i data-lucide="trending-up" class="w-5 h-5"></i>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Charts Row ──────────────────────────────────────────────────────────── -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- Bar Chart: Top Services -->
    <div class="admin-card xl:col-span-2">
      <div class="admin-card-header">
        <h2 class="admin-card-title">
          <i data-lucide="bar-chart-2" class="w-4 h-4" style="color:#f97316;"></i>
          Top 10 Services
        </h2>
        <p class="admin-card-desc">Most subscribed services across all users</p>
      </div>
      <div class="p-6 space-y-3">
        <% const maxCount = topServices.length ? topServices[0].count : 1; %>
        <% topServices.forEach((svc, i) => { %>
          <div class="flex items-center gap-3">
            <span class="text-xs text-slate-500 w-4 text-right flex-shrink-0"><%= i + 1 %></span>
            <span class="text-sm text-slate-300 w-28 flex-shrink-0 truncate"><%= svc.name %></span>
            <div class="flex-1 bg-white/5 rounded-full h-2 overflow-hidden">
              <div class="h-full rounded-full admin-bar-fill" style="width:<%= Math.round((svc.count / maxCount) * 100) %>%"></div>
            </div>
            <span class="text-xs font-semibold text-slate-400 w-6 text-right flex-shrink-0"><%= svc.count %></span>
          </div>
        <% }) %>
        <% if (!topServices.length) { %>
          <p class="text-sm text-slate-500 text-center py-4">No subscriptions yet</p>
        <% } %>
      </div>
    </div>

    <!-- Pie / Donut: Users by sub count -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">
          <i data-lucide="pie-chart" class="w-4 h-4" style="color:#a78bfa;"></i>
          Users by Volume
        </h2>
        <p class="admin-card-desc">Subscriptions per user distribution</p>
      </div>
      <div class="p-6">
        <!-- SVG donut -->
        <%
          const total = subBuckets.reduce((s, b) => s + b.count, 0) || 1;
          const colors = ['#f97316','#a78bfa','#34d399','#60a5fa','#94a3b8'];
          let cumulative = 0;
          const R = 60, cx = 80, cy = 80, stroke = 22;
          const circ = 2 * Math.PI * R;
        %>
        <div class="flex flex-col items-center gap-4">
          <svg viewBox="0 0 160 160" class="w-36 h-36">
            <% subBuckets.forEach((b, i) => { %>
              <% const frac = b.count / total; %>
              <% const dash = frac * circ; %>
              <% const offset = circ - cumulative * circ; %>
              <circle
                cx="<%= cx %>" cy="<%= cy %>" r="<%= R %>"
                fill="none"
                stroke="<%= colors[i % colors.length] %>"
                stroke-width="<%= stroke %>"
                stroke-dasharray="<%= dash.toFixed(2) %> <%= (circ - dash).toFixed(2) %>"
                stroke-dashoffset="<%= offset.toFixed(2) %>"
                transform="rotate(-90 <%= cx %> <%= cy %>)"
                style="opacity:0.85;"
              />
              <% cumulative += frac; %>
            <% }) %>
            <circle cx="<%= cx %>" cy="<%= cy %>" r="<%= R - stroke/2 - 2 %>" fill="rgba(10,10,15,0.9)" />
            <text x="<%= cx %>" y="<%= cy - 6 %>" text-anchor="middle" fill="#f1f5f9" font-size="20" font-weight="700" font-family="Inter,sans-serif"><%= total === 1 && subBuckets.every(b=>b.count===0) ? 0 : subBuckets.reduce((s,b)=>s+b.count,0) %></text>
            <text x="<%= cx %>" y="<%= cy + 10 %>" text-anchor="middle" fill="#64748b" font-size="9" font-family="Inter,sans-serif">USERS</text>
          </svg>
          <div class="w-full space-y-1.5">
            <% subBuckets.forEach((b, i) => { %>
              <div class="flex items-center justify-between text-xs">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-sm flex-shrink-0" style="background:<%= colors[i % colors.length] %>;"></span>
                  <span class="text-slate-400"><%= b.label %> subs</span>
                </div>
                <span class="font-semibold text-slate-300"><%= b.count %></span>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Recent Tables Row ───────────────────────────────────────────────────── -->
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">

    <!-- Recent Users -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">
          <i data-lucide="user-check" class="w-4 h-4" style="color:#fb923c;"></i>
          Recent Users
        </h2>
        <a href="/admin/users" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">View all →</a>
      </div>
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>User</th>
              <th>Role</th>
              <th>Joined</th>
            </tr>
          </thead>
          <tbody>
            <% recentUsers.forEach(u => { %>
              <tr class="sub-row cursor-pointer" onclick="location.href='/admin/users/<%= u.id %>'">
                <td>
                  <div class="flex items-center gap-2.5">
                    <div class="user-avatar user-avatar-sm flex-shrink-0" style="background:linear-gradient(135deg,#f97316,#ef4444);">
                      <span><%= u.username.charAt(0).toUpperCase() %></span>
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-slate-200 truncate"><%= u.username %></p>
                      <p class="text-xs text-slate-500 truncate"><%= u.email %></p>
                    </div>
                  </div>
                </td>
                <td>
                  <% if (u.role === 'admin') { %>
                    <span class="badge-admin">Admin</span>
                  <% } else { %>
                    <span class="text-xs text-slate-500">User</span>
                  <% } %>
                </td>
                <td class="text-xs text-slate-500"><%= new Date(u.createdAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %></td>
              </tr>
            <% }) %>
            <% if (!recentUsers.length) { %>
              <tr><td colspan="3" class="text-center text-slate-500 py-6">No users yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recent Subscriptions -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">
          <i data-lucide="list" class="w-4 h-4" style="color:#a78bfa;"></i>
          Recent Subscriptions
        </h2>
        <a href="/admin/subscriptions" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">View all →</a>
      </div>
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Service</th>
              <th>Owner</th>
              <th>Cost</th>
            </tr>
          </thead>
          <tbody>
            <% recentSubs.forEach(s => { %>
              <tr class="sub-row">
                <td>
                  <p class="text-sm font-medium text-slate-200"><%= s.name %></p>
                  <p class="text-xs text-slate-500"><%= s.category %></p>
                </td>
                <td>
                  <span class="text-xs text-slate-400"><%= s.user.username %></span>
                </td>
                <td class="text-sm font-semibold text-slate-300">
                  <%= formatCurrency(s.cost, s.currency) %>
                  <span class="text-xs text-slate-500">/<%= s.billingCycle === 'monthly' ? 'mo' : s.billingCycle === 'yearly' ? 'yr' : 'wk' %></span>
                </td>
              </tr>
            <% }) %>
            <% if (!recentSubs.length) { %>
              <tr><td colspan="3" class="text-center text-slate-500 py-6">No subscriptions yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>
