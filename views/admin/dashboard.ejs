<div class="p-6 lg:p-8 space-y-8">

  <!-- Page header -->
  <div>
    <h1 class="text-2xl font-bold text-white">Dashboard</h1>
    <p style="font-size:13px;color:var(--muted);margin-top:4px;">Platform overview and key metrics</p>
  </div>

  <!-- ── Stat Cards ─────────────────────────────────────────────────────────── -->
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">

    <!-- Total Users -->
    <div class="admin-stat-card">
      <div class="flex items-start justify-between">
        <div>
          <p class="admin-stat-label">Total Users</p>
          <p class="admin-stat-value"><%= stats.totalUsers %></p>
          <p class="admin-stat-sub">
            <span style="color:var(--neon);">+<%= stats.newUsersThisWeek %></span> this week
          </p>
        </div>
        <div class="admin-stat-icon" style="background:rgba(0,255,135,0.08);color:var(--neon);">
          <i data-lucide="users" class="w-5 h-5"></i>
        </div>
      </div>
    </div>

    <!-- Total Subscriptions -->
    <div class="admin-stat-card">
      <div class="flex items-start justify-between">
        <div>
          <p class="admin-stat-label">Total Subscriptions</p>
          <p class="admin-stat-value"><%= stats.totalSubs %></p>
          <p class="admin-stat-sub">across all users</p>
        </div>
        <div class="admin-stat-icon" style="background:rgba(255,255,255,0.05);color:var(--muted);">
          <i data-lucide="credit-card" class="w-5 h-5"></i>
        </div>
      </div>
    </div>

    <!-- Monthly Revenue -->
    <div class="admin-stat-card">
      <div class="flex items-start justify-between">
        <div>
          <p class="admin-stat-label">Monthly Revenue</p>
          <p class="admin-stat-value">€<%= stats.totalMonthlyRevenue.toFixed(2) %></p>
          <p class="admin-stat-sub">active subscriptions</p>
        </div>
        <div class="admin-stat-icon" style="background:rgba(0,255,135,0.08);color:var(--neon);">
          <i data-lucide="dollar-sign" class="w-5 h-5"></i>
        </div>
      </div>
    </div>

    <!-- Avg per User -->
    <div class="admin-stat-card">
      <div class="flex items-start justify-between">
        <div>
          <p class="admin-stat-label">Average per User</p>
          <p class="admin-stat-value">€<%= stats.avgPerUser.toFixed(2) %></p>
          <p class="admin-stat-sub">monthly spend</p>
        </div>
        <div class="admin-stat-icon" style="background:rgba(255,255,255,0.05);color:var(--muted);">
          <i data-lucide="trending-up" class="w-5 h-5"></i>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Charts Row ──────────────────────────────────────────────────────────── -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- Bar Chart: Top Services -->
    <div class="admin-card xl:col-span-2">
      <div class="admin-card-header">
        <h2 class="admin-card-title">
          <i data-lucide="bar-chart-2" class="w-4 h-4" style="color:var(--neon);"></i>
          Top 10 Services
        </h2>
        <p class="admin-card-desc">Most subscribed services across all users</p>
      </div>
      <div class="p-6 space-y-3">
        <% const maxCount = topServices.length ? topServices[0].count : 1; %>
        <% topServices.forEach((svc, i) => { %>
          <div class="flex items-center gap-3">
            <span style="font-size:11px;color:var(--muted2);width:16px;text-align:right;flex-shrink:0;"><%= i + 1 %></span>
            <span style="font-size:13px;color:var(--muted);width:112px;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= svc.name %></span>
            <div style="flex:1;background:rgba(255,255,255,0.05);border-radius:9999px;height:6px;overflow:hidden;">
              <div class="admin-bar-fill" style="height:100%;border-radius:9999px;width:<%= Math.round((svc.count / maxCount) * 100) %>%;"></div>
            </div>
            <span style="font-size:11px;font-weight:600;color:var(--muted2);width:24px;text-align:right;flex-shrink:0;"><%= svc.count %></span>
          </div>
        <% }) %>
        <% if (!topServices.length) { %>
          <p style="font-size:13px;color:var(--muted2);text-align:center;padding:16px 0;">No subscriptions yet</p>
        <% } %>
      </div>
    </div>

    <!-- Donut: Users by sub count -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">
          <i data-lucide="pie-chart" class="w-4 h-4" style="color:var(--muted);"></i>
          Users by Volume
        </h2>
        <p class="admin-card-desc">Subscriptions per user distribution</p>
      </div>
      <div class="p-6">
        <%
          const total = subBuckets.reduce((s, b) => s + b.count, 0) || 1;
          const colors = ['#00FF87','#ffffff','#888888','#555555','#333333'];
          let cumulative = 0;
          const R = 60, cx = 80, cy = 80, stroke = 22;
          const circ = 2 * Math.PI * R;
        %>
        <div class="flex flex-col items-center gap-4">
          <svg viewBox="0 0 160 160" class="w-36 h-36">
            <% subBuckets.forEach((b, i) => { %>
              <% const frac = b.count / total; %>
              <% const dash = frac * circ; %>
              <% const offset = circ - cumulative * circ; %>
              <circle
                cx="<%= cx %>" cy="<%= cy %>" r="<%= R %>"
                fill="none"
                stroke="<%= colors[i % colors.length] %>"
                stroke-width="<%= stroke %>"
                stroke-dasharray="<%= dash.toFixed(2) %> <%= (circ - dash).toFixed(2) %>"
                stroke-dashoffset="<%= offset.toFixed(2) %>"
                transform="rotate(-90 <%= cx %> <%= cy %>)"
                style="opacity:0.85;"
              />
              <% cumulative += frac; %>
            <% }) %>
            <circle cx="<%= cx %>" cy="<%= cy %>" r="<%= R - stroke/2 - 2 %>" fill="var(--card)" />
            <text x="<%= cx %>" y="<%= cy - 6 %>" text-anchor="middle" fill="#ffffff" font-size="20" font-weight="700" font-family="Inter,sans-serif"><%= subBuckets.reduce((s,b)=>s+b.count,0) %></text>
            <text x="<%= cx %>" y="<%= cy + 10 %>" text-anchor="middle" fill="#555555" font-size="9" font-family="Inter,sans-serif">USERS</text>
          </svg>
          <div class="w-full space-y-1.5">
            <% subBuckets.forEach((b, i) => { %>
              <div class="flex items-center justify-between text-xs">
                <div class="flex items-center gap-2">
                  <span style="width:10px;height:10px;border-radius:2px;flex-shrink:0;background:<%= colors[i % colors.length] %>;"></span>
                  <span style="color:var(--muted2);"><%= b.label %> subs</span>
                </div>
                <span style="font-weight:600;color:var(--muted);"><%= b.count %></span>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Recent Tables Row ───────────────────────────────────────────────────── -->
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">

    <!-- Recent Users -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">
          <i data-lucide="user-check" class="w-4 h-4" style="color:var(--neon);"></i>
          Recent Users
        </h2>
        <a href="/admin/users" style="font-size:12px;color:var(--muted2);text-decoration:none;transition:color var(--transition);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--muted2)'">View all →</a>
      </div>
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>User</th>
              <th>Role</th>
              <th>Joined</th>
            </tr>
          </thead>
          <tbody>
            <% recentUsers.forEach(u => { %>
              <tr class="sub-row cursor-pointer" onclick="location.href='/admin/users/<%= u.id %>'">
                <td>
                  <div class="flex items-center gap-2.5">
                    <div class="user-avatar user-avatar-sm flex-shrink-0">
                      <span><%= u.username.charAt(0).toUpperCase() %></span>
                    </div>
                    <div class="min-w-0">
                      <p style="font-size:13px;font-weight:500;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= u.username %></p>
                      <p style="font-size:11px;color:var(--muted2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= u.email %></p>
                    </div>
                  </div>
                </td>
                <td>
                  <% if (u.role === 'admin') { %>
                    <span class="badge-admin">Admin</span>
                  <% } else { %>
                    <span style="font-size:12px;color:var(--muted2);">User</span>
                  <% } %>
                </td>
                <td style="font-size:11px;color:var(--muted2);"><%= new Date(u.createdAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %></td>
              </tr>
            <% }) %>
            <% if (!recentUsers.length) { %>
              <tr><td colspan="3" style="text-align:center;color:var(--muted2);padding:24px 0;font-size:13px;">No users yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recent Subscriptions -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">
          <i data-lucide="list" class="w-4 h-4" style="color:var(--muted);"></i>
          Recent Subscriptions
        </h2>
        <a href="/admin/subscriptions" style="font-size:12px;color:var(--muted2);text-decoration:none;transition:color var(--transition);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--muted2)'">View all →</a>
      </div>
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Service</th>
              <th>Owner</th>
              <th>Cost</th>
            </tr>
          </thead>
          <tbody>
            <% recentSubs.forEach(s => { %>
              <tr class="sub-row">
                <td>
                  <p style="font-size:13px;font-weight:500;color:var(--text);"><%= s.name %></p>
                  <p style="font-size:11px;color:var(--muted2);"><%= s.category %></p>
                </td>
                <td>
                  <span style="font-size:12px;color:var(--muted);"><%= s.user.username %></span>
                </td>
                <td style="font-size:13px;font-weight:600;color:var(--muted);">
                  <%= formatCurrency(s.cost, s.currency) %>
                  <span style="font-size:11px;color:var(--muted2);">/<%= s.billingCycle === 'monthly' ? 'mo' : s.billingCycle === 'yearly' ? 'yr' : 'wk' %></span>
                </td>
              </tr>
            <% }) %>
            <% if (!recentSubs.length) { %>
              <tr><td colspan="3" style="text-align:center;color:var(--muted2);padding:24px 0;font-size:13px;">No subscriptions yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>
