<div class="p-6 lg:p-8 space-y-6">

  <!-- Page header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-white">User Management</h1>
      <p style="font-size:13px;color:var(--muted);margin-top:4px;"><%= users.length %> total users</p>
    </div>
  </div>

  <!-- Search + Table card -->
  <div class="admin-card">
    <!-- Search bar -->
    <div style="padding:16px;border-bottom:1px solid var(--border);">
      <div class="relative max-w-sm">
        <i data-lucide="search" style="width:16px;height:16px;position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--muted2);pointer-events:none;"></i>
        <input
          type="text"
          id="user-search"
          placeholder="Search by username or email…"
          class="form-input"
          style="padding-left:36px;"
        />
      </div>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
      <table class="data-table" id="users-table">
        <thead>
          <tr>
            <th class="sortable cursor-pointer select-none" data-col="0">
              User <i data-lucide="chevrons-up-down" class="w-3 h-3 inline ml-1 opacity-40"></i>
            </th>
            <th class="sortable cursor-pointer select-none" data-col="1">
              Role <i data-lucide="chevrons-up-down" class="w-3 h-3 inline ml-1 opacity-40"></i>
            </th>
            <th class="sortable cursor-pointer select-none text-right" data-col="2">
              Subs <i data-lucide="chevrons-up-down" class="w-3 h-3 inline ml-1 opacity-40"></i>
            </th>
            <th class="sortable cursor-pointer select-none text-right" data-col="3">
              Monthly <i data-lucide="chevrons-up-down" class="w-3 h-3 inline ml-1 opacity-40"></i>
            </th>
            <th class="sortable cursor-pointer select-none" data-col="4">
              Joined <i data-lucide="chevrons-up-down" class="w-3 h-3 inline ml-1 opacity-40"></i>
            </th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="users-tbody">
          <% users.forEach(u => { %>
            <tr class="sub-row user-row" data-search="<%= u.username.toLowerCase() %> <%= u.email.toLowerCase() %>">
              <td>
                <a href="/admin/users/<%= u.id %>" class="flex items-center gap-3 group" style="text-decoration:none;">
                  <div class="user-avatar user-avatar-sm flex-shrink-0">
                    <span><%= u.username.charAt(0).toUpperCase() %></span>
                  </div>
                  <div class="min-w-0">
                    <p style="font-size:13px;font-weight:500;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;transition:color var(--transition);" class="group-hover:brightness-125"><%= u.username %></p>
                    <p style="font-size:11px;color:var(--muted2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= u.email %></p>
                  </div>
                </a>
              </td>
              <td>
                <% if (u.role === 'admin') { %>
                  <span class="badge-admin">Admin</span>
                <% } else { %>
                  <span class="admin-badge-user">User</span>
                <% } %>
              </td>
              <td style="text-align:right;font-size:13px;color:var(--muted);font-weight:500;" data-sort="<%= u.subCount %>">
                <%= u.subCount %>
              </td>
              <td style="text-align:right;font-size:13px;font-weight:600;color:var(--muted);" data-sort="<%= u.monthlyTotal.toFixed(2) %>">
                €<%= u.monthlyTotal.toFixed(2) %>
              </td>
              <td style="font-size:12px;color:var(--muted2);" data-sort="<%= new Date(u.createdAt).getTime() %>">
                <%= new Date(u.createdAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %>
              </td>
              <td>
                <div class="flex items-center gap-2">
                  <a href="/admin/users/<%= u.id %>" class="admin-action-btn">
                    <i data-lucide="eye" class="w-3.5 h-3.5"></i> View
                  </a>
                  <% if (u.id === currentUser.id) { %>
                    <button class="admin-action-btn-danger" style="opacity:0.4;cursor:not-allowed;" disabled title="Cannot delete yourself">
                      <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete
                    </button>
                  <% } else { %>
                    <button
                      class="admin-action-btn-danger"
                      onclick="openDeleteUserModal(<%= u.id %>, '<%= u.username.replace(/'/g, "\\'") %>')"
                    >
                      <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete
                    </button>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <div id="no-results" class="hidden" style="text-align:center;padding:40px 0;color:var(--muted2);font-size:13px;">
        No users match your search.
      </div>
    </div>
  </div>
</div>

<!-- Delete User Modal -->
<div id="delete-user-modal" class="modal-backdrop hidden" onclick="if(event.target===this)closeDeleteUserModal()">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="flex items-center gap-3 mb-4">
      <div style="width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(255,68,68,0.1);border:1px solid rgba(255,68,68,0.2);">
        <i data-lucide="alert-triangle" style="width:20px;height:20px;color:var(--danger);"></i>
      </div>
      <div>
        <h3 style="font-weight:600;color:var(--text);">Delete User</h3>
        <p style="font-size:12px;color:var(--muted2);">This action cannot be undone</p>
      </div>
    </div>
    <p style="font-size:14px;color:var(--muted);margin-bottom:8px;">
      You are about to delete user <strong id="delete-user-name" style="color:var(--text);"></strong>.
    </p>
    <p style="font-size:14px;color:var(--danger);margin-bottom:24px;">All their subscriptions will also be permanently deleted.</p>
    <div class="flex gap-3">
      <button onclick="closeDeleteUserModal()" class="btn-ghost flex-1 justify-center">Cancel</button>
      <form id="delete-user-form" method="POST" action="" class="flex-1 m-0">
        <input type="hidden" name="_method" value="DELETE" />
        <button type="submit" class="btn-danger w-full justify-center">
          <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete User
        </button>
      </form>
    </div>
  </div>
</div>

<script>
function openDeleteUserModal(id, username) {
  document.getElementById('delete-user-name').textContent = username;
  document.getElementById('delete-user-form').action = '/admin/users/' + id;
  document.getElementById('delete-user-modal').classList.remove('hidden');
}
function closeDeleteUserModal() {
  document.getElementById('delete-user-modal').classList.add('hidden');
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDeleteUserModal(); });
</script>
