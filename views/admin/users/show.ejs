<div class="p-6 lg:p-8 space-y-6">

  <!-- Back + header -->
  <div class="flex flex-col sm:flex-row sm:items-center gap-4">
    <a href="/admin/users" class="admin-action-btn self-start">
      <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i> Back to Users
    </a>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- User info card -->
    <div class="admin-card xl:col-span-1">
      <div class="p-6 space-y-5">
        <!-- Avatar + name -->
        <div class="flex flex-col items-center text-center gap-3 pb-5 border-b border-white/5">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-2xl font-bold text-white" style="background:linear-gradient(135deg,#f97316,#ef4444);">
            <%= user.username.charAt(0).toUpperCase() %>
          </div>
          <div>
            <h2 class="text-lg font-bold text-white"><%= user.username %></h2>
            <p class="text-sm text-slate-500"><%= user.email %></p>
          </div>
          <% if (user.role === 'admin') { %>
            <span class="badge-admin">Administrator</span>
          <% } else { %>
            <span class="admin-badge-user">Regular User</span>
          <% } %>
        </div>

        <!-- Meta -->
        <div class="space-y-3 text-sm">
          <div class="flex justify-between">
            <span class="text-slate-500">User ID</span>
            <span class="text-slate-300 font-mono">#<%= user.id %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-slate-500">Registered</span>
            <span class="text-slate-300"><%= new Date(user.createdAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-slate-500">Last updated</span>
            <span class="text-slate-300"><%= new Date(user.updatedAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %></span>
          </div>
        </div>

        <!-- Delete section -->
        <% if (user.id !== currentUser.id) { %>
          <div class="pt-4 border-t border-white/5">
            <p class="text-xs text-slate-500 mb-3">Deleting this user will permanently remove all their subscriptions.</p>
            <button onclick="document.getElementById('delete-modal').classList.remove('hidden')" class="btn-danger w-full justify-center">
              <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete User
            </button>
          </div>
        <% } else { %>
          <div class="pt-4 border-t border-white/5">
            <p class="text-xs text-slate-500 text-center">You cannot delete your own account.</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Right column: stats + subscriptions -->
    <div class="xl:col-span-2 space-y-6">

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-4">
        <div class="admin-stat-card text-center">
          <p class="admin-stat-label text-center">Subscriptions</p>
          <p class="admin-stat-value text-center"><%= stats.subCount %></p>
        </div>
        <div class="admin-stat-card text-center">
          <p class="admin-stat-label text-center">Monthly</p>
          <p class="admin-stat-value text-center">€<%= stats.monthlyTotal.toFixed(2) %></p>
        </div>
        <div class="admin-stat-card text-center">
          <p class="admin-stat-label text-center">Yearly</p>
          <p class="admin-stat-value text-center">€<%= stats.yearlyTotal.toFixed(2) %></p>
        </div>
      </div>

      <!-- Subscriptions table -->
      <div class="admin-card">
        <div class="admin-card-header">
          <h2 class="admin-card-title">
            <i data-lucide="credit-card" class="w-4 h-4" style="color:#a78bfa;"></i>
            Subscriptions
          </h2>
          <span class="text-xs text-slate-500"><%= user.subscriptions.length %> total</span>
        </div>
        <div class="overflow-x-auto">
          <table class="data-table">
            <thead>
              <tr>
                <th>Service</th>
                <th>Category</th>
                <th class="text-right">Cost</th>
                <th>Cycle</th>
                <th>Status</th>
                <th>Next Payment</th>
              </tr>
            </thead>
            <tbody>
              <% user.subscriptions.forEach(s => { %>
                <tr class="sub-row">
                  <td class="font-medium text-slate-200"><%= s.name %></td>
                  <td class="text-xs text-slate-500"><%= s.category %></td>
                  <td class="text-right font-semibold text-slate-300">
                    <%= formatCurrency(s.cost, s.currency) %>
                  </td>
                  <td class="text-xs text-slate-500 capitalize"><%= s.billingCycle %></td>
                  <td>
                    <span class="badge badge-<%= s.status %>"><%= s.status %></span>
                  </td>
                  <td class="text-xs text-slate-500">
                    <%= s.nextPayment ? new Date(s.nextPayment).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) : '—' %>
                  </td>
                </tr>
              <% }) %>
              <% if (!user.subscriptions.length) { %>
                <tr><td colspan="6" class="text-center text-slate-500 py-8">No subscriptions</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Delete Modal -->
<div id="delete-modal" class="modal-backdrop hidden" onclick="if(event.target===this)this.classList.add('hidden')">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(239,68,68,0.15);">
        <i data-lucide="alert-triangle" class="w-5 h-5" style="color:#f87171;"></i>
      </div>
      <div>
        <h3 class="font-semibold text-white">Delete User</h3>
        <p class="text-xs text-slate-500">This action cannot be undone</p>
      </div>
    </div>
    <p class="text-sm text-slate-400 mb-2">
      You are about to delete <strong class="text-white"><%= user.username %></strong>.
    </p>
    <p class="text-sm text-red-400 mb-6">All <strong><%= user.subscriptions.length %></strong> of their subscriptions will also be permanently deleted.</p>
    <div class="flex gap-3">
      <button onclick="document.getElementById('delete-modal').classList.add('hidden')" class="btn-ghost flex-1 justify-center">Cancel</button>
      <form action="/admin/users/<%= user.id %>?_method=DELETE" method="POST" class="flex-1 m-0">
        <button type="submit" class="btn-danger w-full justify-center">
          <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete
        </button>
      </form>
    </div>
  </div>
</div>

<script>
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.getElementById('delete-modal').classList.add('hidden');
});
</script>
