<div class="p-6 lg:p-8 space-y-6">

  <!-- Back + header -->
  <div class="flex flex-col sm:flex-row sm:items-center gap-4">
    <a href="/admin/users" class="admin-action-btn self-start">
      <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i> Back to Users
    </a>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- User info card -->
    <div class="admin-card xl:col-span-1">
      <div class="p-6 space-y-5">
        <!-- Avatar + name -->
        <div style="display:flex;flex-direction:column;align-items:center;text-align:center;gap:12px;padding-bottom:20px;border-bottom:1px solid var(--border);">
          <div class="user-avatar" style="width:64px;height:64px;font-size:24px;border-radius:16px;">
            <%= user.username.charAt(0).toUpperCase() %>
          </div>
          <div>
            <h2 style="font-size:17px;font-weight:700;color:var(--text);"><%= user.username %></h2>
            <p style="font-size:13px;color:var(--muted2);"><%= user.email %></p>
          </div>
          <% if (user.role === 'admin') { %>
            <span class="badge-admin">Administrator</span>
          <% } else { %>
            <span class="admin-badge-user">Regular User</span>
          <% } %>
        </div>

        <!-- Meta -->
        <div style="display:flex;flex-direction:column;gap:12px;font-size:13px;">
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--muted2);">User ID</span>
            <span style="color:var(--muted);font-family:monospace;">#<%= user.id %></span>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--muted2);">Registered</span>
            <span style="color:var(--muted);"><%= new Date(user.createdAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %></span>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--muted2);">Last updated</span>
            <span style="color:var(--muted);"><%= new Date(user.updatedAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %></span>
          </div>
        </div>

        <!-- Delete section -->
        <% if (user.id !== currentUser.id) { %>
          <div style="padding-top:16px;border-top:1px solid var(--border);">
            <p style="font-size:12px;color:var(--muted2);margin-bottom:12px;">Deleting this user will permanently remove all their subscriptions.</p>
            <button onclick="document.getElementById('delete-modal').classList.remove('hidden')" class="btn-danger w-full justify-center">
              <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete User
            </button>
          </div>
        <% } else { %>
          <div style="padding-top:16px;border-top:1px solid var(--border);">
            <p style="font-size:12px;color:var(--muted2);text-align:center;">You cannot delete your own account.</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Right column: stats + subscriptions -->
    <div class="xl:col-span-2 space-y-6">

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-4">
        <div class="admin-stat-card text-center">
          <p class="admin-stat-label text-center">Subscriptions</p>
          <p class="admin-stat-value text-center"><%= stats.subCount %></p>
        </div>
        <div class="admin-stat-card text-center">
          <p class="admin-stat-label text-center">Monthly</p>
          <p class="admin-stat-value text-center" style="color:var(--neon);">€<%= stats.monthlyTotal.toFixed(2) %></p>
        </div>
        <div class="admin-stat-card text-center">
          <p class="admin-stat-label text-center">Yearly</p>
          <p class="admin-stat-value text-center">€<%= stats.yearlyTotal.toFixed(2) %></p>
        </div>
      </div>

      <!-- Subscriptions table -->
      <div class="admin-card">
        <div class="admin-card-header">
          <h2 class="admin-card-title">
            <i data-lucide="credit-card" class="w-4 h-4" style="color:var(--muted);"></i>
            Subscriptions
          </h2>
          <span style="font-size:12px;color:var(--muted2);"><%= user.subscriptions.length %> total</span>
        </div>
        <div class="overflow-x-auto">
          <table class="data-table">
            <thead>
              <tr>
                <th>Service</th>
                <th>Category</th>
                <th class="text-right">Cost</th>
                <th>Cycle</th>
                <th>Status</th>
                <th>Next Payment</th>
              </tr>
            </thead>
            <tbody>
              <% user.subscriptions.forEach(s => { %>
                <tr class="sub-row">
                  <td style="font-weight:500;color:var(--text);"><%= s.name %></td>
                  <td style="font-size:12px;color:var(--muted2);"><%= s.category %></td>
                  <td style="text-align:right;font-weight:600;color:var(--muted);">
                    <%= formatCurrency(s.cost, s.currency) %>
                  </td>
                  <td style="font-size:12px;color:var(--muted2);text-transform:capitalize;"><%= s.billingCycle %></td>
                  <td>
                    <span class="status-badge status-<%= s.status %>"><span class="status-dot"></span><%= s.status %></span>
                  </td>
                  <td style="font-size:12px;color:var(--muted2);">
                    <%= s.nextPayment ? new Date(s.nextPayment).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) : '—' %>
                  </td>
                </tr>
              <% }) %>
              <% if (!user.subscriptions.length) { %>
                <tr><td colspan="6" style="text-align:center;color:var(--muted2);padding:32px 0;font-size:13px;">No subscriptions</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Delete Modal -->
<div id="delete-modal" class="modal-backdrop hidden" onclick="if(event.target===this)this.classList.add('hidden')">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="flex items-center gap-3 mb-4">
      <div style="width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(255,68,68,0.1);border:1px solid rgba(255,68,68,0.2);">
        <i data-lucide="alert-triangle" style="width:20px;height:20px;color:var(--danger);"></i>
      </div>
      <div>
        <h3 style="font-weight:600;color:var(--text);">Delete User</h3>
        <p style="font-size:12px;color:var(--muted2);">This action cannot be undone</p>
      </div>
    </div>
    <p style="font-size:14px;color:var(--muted);margin-bottom:8px;">
      You are about to delete <strong style="color:var(--text);"><%= user.username %></strong>.
    </p>
    <p style="font-size:14px;color:var(--danger);margin-bottom:24px;">All <strong><%= user.subscriptions.length %></strong> of their subscriptions will also be permanently deleted.</p>
    <div class="flex gap-3">
      <button onclick="document.getElementById('delete-modal').classList.add('hidden')" class="btn-ghost flex-1 justify-center">Cancel</button>
      <form action="/admin/users/<%= user.id %>?_method=DELETE" method="POST" class="flex-1 m-0">
        <button type="submit" class="btn-danger w-full justify-center">
          <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete
        </button>
      </form>
    </div>
  </div>
</div>

<script>
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.getElementById('delete-modal').classList.add('hidden');
});
</script>
