<div class="min-h-screen flex items-center justify-center px-4 py-16">
  <div class="w-full max-w-md">

    <!-- Icon -->
    <div class="text-center mb-8">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-purple-500 to-blue-500 flex items-center justify-center mx-auto mb-5 shadow-lg shadow-purple-500/30">
        <i data-lucide="key-round" class="w-8 h-8 text-white"></i>
      </div>
      <h1 class="text-2xl font-bold text-white">Reset your password</h1>
      <p class="text-slate-400 mt-2 text-sm">
