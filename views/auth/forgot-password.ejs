<!-- ── Forgot Password Page (stub) ─────────────────────────────────────────── -->
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:40px 16px;">
  <div style="width:100%;max-width:420px;">

    <!-- Icon -->
    <div style="text-align:center;margin-bottom:32px;">
      <div style="width:64px;height:64px;border-radius:16px;background:rgba(0,255,135,0.08);border:1px solid rgba(0,255,135,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
        <i data-lucide="key-round" style="width:32px;height:32px;color:var(--neon);"></i>
      </div>
      <h1 class="text-2xl font-bold text-white">Reset your password</h1>
      <p style="color:var(--muted);margin-top:8px;font-size:14px;">
        Enter your email and we'll send a reset link.
      </p>
    </div>

    <!-- Card -->
    <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-card);padding:32px;">
      <div style="margin-bottom:20px;padding:16px;border-radius:8px;background:rgba(255,184,0,0.08);border:1px solid rgba(255,184,0,0.2);">
        <p style="font-size:12px;color:var(--warn);text-align:center;font-weight:500;">
          <i data-lucide="construction" class="w-3.5 h-3.5 inline-block mr-1"></i>
          Password reset is coming soon. Please use demo credentials to sign in.
        </p>
      </div>

      <form action="#" method="POST" novalidate>
        <div class="mb-5">
          <label for="email" class="form-label">
            <i data-lucide="mail" class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5"></i>
            Email address
          </label>
          <input
            id="email"
            name="email"
            type="email"
            class="form-input"
            placeholder="you@example.com"
            autocomplete="email"
            disabled
          />
        </div>

        <button type="button" disabled class="btn-primary w-full justify-center" style="padding:12px;font-size:15px;opacity:0.4;cursor:not-allowed;">
          <i data-lucide="send" class="w-5 h-5"></i>
          Send Reset Link
        </button>
      </form>
    </div>

    <p style="text-align:center;margin-top:24px;">
      <a href="/login" style="font-size:14px;color:var(--muted2);text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:color var(--transition);" onmouseover="this.style.color='var(--neon)'" onmouseout="this.style.color='var(--muted2)'">
        <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i>
        Back to Sign In
      </a>
    </p>

  </div>
</div>
