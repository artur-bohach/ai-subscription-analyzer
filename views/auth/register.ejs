<!-- ── Register Page (FR5) ──────────────────────────────────────────────────── -->
<div class="auth-page">

  <!-- ── Left: Brand Panel ───────────────────────────────────────────────────── -->
  <div class="auth-brand">
    <div class="auth-brand-inner">
      <!-- Logo -->
      <a href="/" class="auth-brand-logo">
        <div class="auth-logo-icon">
          <i data-lucide="layers" class="w-7 h-7 text-white"></i>
        </div>
        <span class="text-xl font-bold text-white">Sub<span class="gradient-text">Tracker</span></span>
      </a>

      <!-- Headline -->
      <div class="auth-brand-headline">
        <h1 class="text-3xl font-extrabold text-white leading-tight">
          Take control of<br/>your subscriptions
        </h1>
        <p class="text-slate-400 mt-3 text-sm leading-relaxed">
          Track every service, analyse your spending,<br class="hidden xl:block"/>
          and stop paying for things you don't use.
        </p>
      </div>

      <!-- Features list -->
      <ul class="auth-brand-features">
        <li>
          <span class="auth-feat-icon"><i data-lucide="check" class="w-3.5 h-3.5"></i></span>
          Track unlimited subscriptions
        </li>
        <li>
          <span class="auth-feat-icon"><i data-lucide="check" class="w-3.5 h-3.5"></i></span>
          Monthly &amp; yearly spending insights
        </li>
        <li>
          <span class="auth-feat-icon"><i data-lucide="check" class="w-3.5 h-3.5"></i></span>
          Renewal reminders &amp; alerts
        </li>
        <li>
          <span class="auth-feat-icon"><i data-lucide="check" class="w-3.5 h-3.5"></i></span>
          Multi-currency support
        </li>
      </ul>

      <!-- Decorative orb -->
      <div class="auth-brand-orb"></div>
    </div>
  </div>

  <!-- ── Right: Form Panel ───────────────────────────────────────────────────── -->
  <div class="auth-form-panel">
    <div class="auth-form-inner">

      <!-- Header -->
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-white">Create your account</h2>
        <p class="text-slate-400 text-sm mt-1.5">
          Already have an account?
          <a href="/login" class="text-purple-400 hover:text-purple-300 font-medium transition-colors">Sign in</a>
        </p>
      </div>

      <!-- Registration Form -->
      <form id="register-form" action="/register" method="POST" novalidate>

        <!-- Username -->
        <div class="mb-5">
          <label for="username" class="form-label">
            <i data-lucide="user" class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5"></i>
            Username
          </label>
          <div class="relative">
            <input
              id="username"
              name="username"
              type="text"
              class="form-input<% if (fieldErrors.username) { %> is-error<% } %>"
              placeholder="cooluser"
              value="<%= formData.username || '' %>"
              autocomplete="username"
              autocapitalize="none"
              maxlength="30"
              required
            />
          </div>
          <% if (fieldErrors.username) { %>
            <p class="field-error-msg show">⚠ <%= fieldErrors.username %></p>
          <% } %>
        </div>

        <!-- Email -->
        <div class="mb-5">
          <label for="email" class="form-label">
            <i data-lucide="mail" class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5"></i>
            Email address
          </label>
          <input
            id="email"
            name="email"
            type="email"
            class="form-input<% if (fieldErrors.email) { %> is-error<% } %>"
            placeholder="you@example.com"
            value="<%= formData.email || '' %>"
            autocomplete="email"
            required
          />
          <% if (fieldErrors.email) { %>
            <p class="field-error-msg show">⚠ <%= fieldErrors.email %></p>
          <% } %>
        </div>

        <!-- Password -->
        <div class="mb-2">
          <label for="password" class="form-label">
            <i data-lucide="lock" class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5"></i>
            Password
          </label>
          <div class="relative">
            <input
              id="password"
              name="password"
              type="password"
              class="form-input pr-11<% if (fieldErrors.password) { %> is-error<% } %>"
              placeholder="Min. 6 characters"
              autocomplete="new-password"
              required
            />
            <button
              type="button"
              class="pwd-toggle"
              data-toggle-password="password"
              aria-label="Toggle password visibility"
            >
              <i data-lucide="eye" class="w-4 h-4"></i>
            </button>
          </div>
          <% if (fieldErrors.password) { %>
            <p class="field-error-msg show">⚠ <%= fieldErrors.password %></p>
          <% } %>
        </div>

        <!-- Password Strength Bar -->
        <div class="pwr-wrap mb-5" id="pwr-wrap">
          <div class="pwr-bar" aria-hidden="true">
            <span class="pwr-seg" id="pwr-s1"></span>
            <span class="pwr-seg" id="pwr-s2"></span>
            <span class="pwr-seg" id="pwr-s3"></span>
            <span class="pwr-seg" id="pwr-s4"></span>
          </div>
          <span class="pwr-label" id="pwr-label"></span>
        </div>

        <!-- Confirm Password -->
        <div class="mb-6">
          <label for="confirmPassword" class="form-label">
            <i data-lucide="lock" class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5"></i>
            Confirm password
          </label>
          <div class="relative">
            <input
              id="confirmPassword"
              name="confirmPassword"
              type="password"
              class="form-input pr-11<% if (fieldErrors.confirmPassword) { %> is-error<% } %>"
              placeholder="Repeat your password"
              autocomplete="new-password"
              required
            />
            <button
              type="button"
              class="pwd-toggle"
              data-toggle-password="confirmPassword"
              aria-label="Toggle confirm password visibility"
            >
              <i data-lucide="eye" class="w-4 h-4"></i>
            </button>
          </div>
          <% if (fieldErrors.confirmPassword) { %>
            <p class="field-error-msg show">⚠ <%= fieldErrors.confirmPassword %></p>
          <% } %>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn-gradient w-full justify-center py-3 text-base">
          <i data-lucide="user-plus" class="w-5 h-5"></i>
          Create Account
        </button>
      </form>

      <!-- Divider -->
      <div class="auth-divider"><span>or</span></div>

      <!-- Sign in link -->
      <p class="text-center text-sm text-slate-400">
        Already a member?
        <a href="/login" class="text-purple-400 hover:text-purple-300 font-medium transition-colors">Sign in to your account</a>
      </p>

    </div>
  </div>

</div>
