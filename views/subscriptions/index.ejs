<%
  // Category color map
  const catColors = {
    'Entertainment':    'text-pink-400 bg-pink-500/10',
    'Productivity':     'text-blue-400 bg-blue-500/10',
    'Education':        'text-yellow-400 bg-yellow-500/10',
    'Cloud & Storage':  'text-cyan-400 bg-cyan-500/10',
    'Music & Audio':    'text-purple-400 bg-purple-500/10',
    'AI Tools':         'text-violet-400 bg-violet-500/10',
    'Health & Fitness': 'text-emerald-400 bg-emerald-500/10',
    'News & Media':     'text-orange-400 bg-orange-500/10',
    'Other':            'text-slate-400 bg-slate-500/10'
  };
%>

<!-- ── Page Header ─────────────────────────────────────────────────────── -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="page-header flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-white flex items-center gap-2">
        <i data-lucide="credit-card" class="w-6 h-6 text-purple-400"></i>
        My Subscriptions
      </h1>
      <p class="text-slate-500 text-sm mt-1">
        Manage and track all your recurring payments
      </p>
    </div>
    <a href="/subscriptions/new" class="btn-gradient text-sm self-start sm:self-auto">
      <i data-lucide="plus" class="w-4 h-4"></i>
      Add Subscription
    </a>
  </div>

  <!-- ── Summary Cards ────────────────────────────────────────────────── -->
  <div class="grid sm:grid-cols-3 gap-4 mb-8">

    <!-- Monthly Total -->
    <div class="stat-card">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Monthly Total</span>
        <div class="w-9 h-9 rounded-lg bg-purple-500/15 flex items-center justify-center">
          <i data-lucide="calendar" class="w-4.5 h-4.5 text-purple-400" style="width:1.125rem;height:1.125rem;"></i>
        </div>
      </div>
      <p class="text-3xl font-extrabold text-white">€<%= monthlyTotal %></p>
      <p class="text-xs text-slate-500 mt-1">across all active plans</p>
    </div>

    <!-- Yearly Total -->
    <div class="stat-card">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Yearly Total</span>
        <div class="w-9 h-9 rounded-lg bg-blue-500/15 flex items-center justify-center">
          <i data-lucide="trending-up" class="w-4.5 h-4.5 text-blue-400" style="width:1.125rem;height:1.125rem;"></i>
        </div>
      </div>
      <p class="text-3xl font-extrabold text-white">€<%= yearlyTotal %></p>
      <p class="text-xs text-slate-500 mt-1">projected annual spend</p>
    </div>

    <!-- Active Count -->
    <div class="stat-card">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Active Plans</span>
        <div class="w-9 h-9 rounded-lg bg-emerald-500/15 flex items-center justify-center">
          <i data-lucide="check-circle-2" class="w-4.5 h-4.5 text-emerald-400" style="width:1.125rem;height:1.125rem;"></i>
        </div>
      </div>
      <p class="text-3xl font-extrabold text-white"><%= activeCount %></p>
      <p class="text-xs text-slate-500 mt-1">of <%= subscriptions.length %> total subscriptions</p>
    </div>
  </div>

  <!-- ── Subscriptions Table ──────────────────────────────────────────── -->
  <% if (subscriptions.length === 0) { %>
    <!-- Empty State -->
    <div class="glass rounded-2xl p-16 text-center">
      <div class="w-20 h-20 rounded-2xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center mx-auto mb-5">
        <i data-lucide="inbox" class="w-10 h-10 text-purple-400"></i>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">No subscriptions yet</h3>
      <p class="text-slate-500 text-sm mb-6">Start tracking your recurring payments today.</p>
      <a href="/subscriptions/new" class="btn-gradient">
        <i data-lucide="plus" class="w-4 h-4"></i>
        Add your first subscription
      </a>
    </div>
  <% } else { %>
    <div class="glass rounded-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Service</th>
              <th>Category</th>
              <th>Cost</th>
              <th>Cycle</th>
              <th>Next Payment</th>
              <th>Status</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% subscriptions.forEach(sub => {
              const statusClass = getStatusClasses(sub.status);
              const catClass = catColors[sub.category] || 'text-slate-400 bg-slate-500/10';
              const monthly = normalizeToMonthly(Number(sub.cost), sub.billingCycle);
            %>
              <tr class="sub-row" onclick="window.location='/subscriptions/<%= sub.id %>'" style="cursor:pointer;" title="View <%= sub.name %> details">
                <!-- Service Name -->
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-purple-600/30 to-blue-600/30 flex items-center justify-center flex-shrink-0">
                      <i data-lucide="<%= getCategoryIcon(sub.category) %>" class="w-4 h-4 text-purple-300"></i>
                    </div>
                    <div>
                      <p class="font-semibold text-white text-sm"><%= sub.name %></p>
                      <p class="text-xs text-slate-500">
                        ≈ €<%= monthly.toFixed(2) %>/mo
                      </p>
                    </div>
                  </div>
                </td>

                <!-- Category -->
                <td>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-medium <%= catClass %>">
                    <i data-lucide="<%= getCategoryIcon(sub.category) %>" class="w-3 h-3"></i>
                    <%= sub.category %>
                  </span>
                </td>

                <!-- Cost -->
                <td>
                  <span class="font-semibold text-white"><%= formatCurrency(Number(sub.cost), sub.currency) %></span>
                </td>

                <!-- Billing Cycle -->
                <td>
                  <span class="text-slate-400 capitalize text-sm"><%= sub.billingCycle %></span>
                </td>

                <!-- Next Payment -->
                <td>
                  <span class="text-slate-400 text-sm">
                    <% if (sub.nextPayment) { %>
                      <%= formatDateDisplay(sub.nextPayment) %>
                    <% } else { %>
                      —
                    <% } %>
                  </span>
                </td>

                <!-- Status Badge -->
                <td>
                  <span class="badge badge-<%= sub.status %>">
                    <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                    <%= sub.status %>
                  </span>
                </td>

                <!-- Action Buttons -->
                <td onclick="event.stopPropagation()">
                  <div class="flex items-center justify-end gap-2">
                    <a href="/subscriptions/<%= sub.id %>" class="btn-ghost text-xs py-1.5 px-3">
                      <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                      View
                    </a>
                    <a href="/subscriptions/<%= sub.id %>/edit" class="btn-ghost text-xs py-1.5 px-3">
                      <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                      Edit
                    </a>
                    <!-- Delete Button triggers modal -->
                    <button
                      type="button"
                      data-delete-form="delete-form-<%= sub.id %>"
                      class="btn-danger"
                    >
                      <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                    </button>
                    <!-- Hidden delete form -->
                    <form
                      id="delete-form-<%= sub.id %>"
                      action="/subscriptions/<%= sub.id %>?_method=DELETE"
                      method="POST"
                      style="display:none;"
                    ></form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

  <div class="py-8"></div>
</div>

<!-- ── Delete Confirmation Modal ────────────────────────────────────────── -->
<div id="delete-modal" class="modal-backdrop" style="display:none;">
  <div class="modal-box">
    <div class="text-center">
      <div class="w-14 h-14 rounded-2xl bg-red-500/15 border border-red-500/20 flex items-center justify-center mx-auto mb-5">
        <i data-lucide="trash-2" class="w-7 h-7 text-red-400"></i>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">Delete Subscription?</h3>
      <p class="text-slate-400 text-sm mb-6">
        This action cannot be undone. The subscription and all its data will be permanently removed.
      </p>
      <div class="flex gap-3 justify-center">
        <button id="cancel-delete" class="btn-ghost px-6 py-2.5 flex-1">
          Cancel
        </button>
        <button id="confirm-delete" class="btn-danger px-6 py-2.5 flex-1 justify-center">
          <i data-lucide="trash-2" class="w-4 h-4"></i>
          Delete
        </button>
      </div>
    </div>
  </div>
</div>
