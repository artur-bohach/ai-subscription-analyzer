<!-- ── Page Header ─────────────────────────────────────────────────────── -->
<div class="page-wrap">
  <div class="page-header-row">
    <div>
      <h1 class="page-title">My Subscriptions</h1>
      <p class="page-sub">Manage and track all your recurring payments</p>
    </div>
    <a href="/subscriptions/new" class="btn-primary" style="font-size:13px;padding:8px 16px">
      <i data-lucide="plus" class="w-4 h-4"></i>
      Add Subscription
    </a>
  </div>

  <!-- ── Summary Cards ────────────────────────────────────────────────── -->
  <div class="db-stat-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:20px">

    <div class="db-stat-card" data-tilt>
      <div class="db-stat-icon"><i data-lucide="calendar" class="w-4 h-4"></i></div>
      <div class="db-stat-label">Monthly Total</div>
      <div class="db-stat-value">€<span data-countup data-target="<%= monthlyTotal %>" data-decimals="2"><%= monthlyTotal %></span></div>
      <div class="db-stat-sub">across all active plans</div>
    </div>

    <div class="db-stat-card" data-tilt>
      <div class="db-stat-icon"><i data-lucide="trending-up" class="w-4 h-4"></i></div>
      <div class="db-stat-label">Yearly Total</div>
      <div class="db-stat-value">€<span data-countup data-target="<%= yearlyTotal %>" data-decimals="2"><%= yearlyTotal %></span></div>
      <div class="db-stat-sub">projected annual spend</div>
    </div>

    <div class="db-stat-card" data-tilt>
      <div class="db-stat-icon" style="color:var(--neon)"><i data-lucide="check-circle-2" class="w-4 h-4"></i></div>
      <div class="db-stat-label">Active Plans</div>
      <div class="db-stat-value" style="color:var(--neon)"><span data-countup data-target="<%= activeCount %>"><%= activeCount %></span></div>
      <div class="db-stat-sub">of <%= subscriptions.length %> total subscriptions</div>
    </div>
  </div>

  <!-- ── Subscriptions Table ──────────────────────────────────────────── -->
  <% if (subscriptions.length === 0) { %>
    <div class="db-empty" style="min-height:40vh">
      <div class="db-empty-icon">
        <i data-lucide="inbox" class="w-10 h-10"></i>
      </div>
      <h3>No subscriptions yet</h3>
      <p>Start tracking your recurring payments today.</p>
      <a href="/subscriptions/new" class="btn-primary" style="font-size:13px;padding:9px 20px">
        <i data-lucide="plus" class="w-4 h-4"></i>
        Add your first subscription
      </a>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <div style="overflow-x:auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Service</th>
              <th>Category</th>
              <th>Cost</th>
              <th>Cycle</th>
              <th>Next Payment</th>
              <th>Status</th>
              <th style="text-align:right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% subscriptions.forEach(sub => {
              const monthly = normalizeToMonthly(Number(sub.cost), sub.billingCycle);
            %>
              <tr class="sub-row" onclick="window.location='/subscriptions/<%= sub.id %>'" style="cursor:pointer" title="View <%= sub.name %> details">

                <!-- Service -->
                <td>
                  <div class="service-cell">
                    <div class="service-icon">
                      <i data-lucide="<%= getCategoryIcon(sub.category) %>" class="w-4 h-4"></i>
                    </div>
                    <div>
                      <p class="service-name"><%= sub.name %></p>
                      <p class="service-meta">≈ €<%= monthly.toFixed(2) %>/mo</p>
                    </div>
                  </div>
                </td>

                <!-- Category -->
                <td>
                  <span class="cat-badge">
                    <i data-lucide="<%= getCategoryIcon(sub.category) %>" class="w-3 h-3"></i>
                    <%= sub.category %>
                  </span>
                </td>

                <!-- Cost -->
                <td><span class="font-semibold"><%= formatCurrency(Number(sub.cost), sub.currency) %></span></td>

                <!-- Billing Cycle -->
                <td><span style="color:var(--muted);font-size:13px;text-transform:capitalize"><%= sub.billingCycle %></span></td>

                <!-- Next Payment -->
                <td>
                  <span style="color:var(--muted);font-size:13px">
                    <% if (sub.nextPayment) { %>
                      <%= formatDateDisplay(sub.nextPayment) %>
                    <% } else { %>
                      —
                    <% } %>
                  </span>
                </td>

                <!-- Status -->
                <td>
                  <span class="status-badge status-<%= sub.status %>">
                    <span class="status-dot"></span>
                    <%= sub.status %>
                  </span>
                </td>

                <!-- Actions -->
                <td onclick="event.stopPropagation()">
                  <div class="table-actions">
                    <a href="/subscriptions/<%= sub.id %>" class="btn-ghost" style="font-size:12px;padding:5px 10px">
                      <i data-lucide="eye" class="w-3.5 h-3.5"></i> View
                    </a>
                    <a href="/subscriptions/<%= sub.id %>/edit" class="btn-ghost" style="font-size:12px;padding:5px 10px">
                      <i data-lucide="pencil" class="w-3.5 h-3.5"></i> Edit
                    </a>
                    <button
                      type="button"
                      data-delete-form="delete-form-<%= sub.id %>"
                      class="btn-danger" style="font-size:12px;padding:5px 10px"
                    >
                      <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                    </button>
                    <form id="delete-form-<%= sub.id %>" action="/subscriptions/<%= sub.id %>?_method=DELETE" method="POST" style="display:none"></form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

</div><!-- /page-wrap -->

<!-- ── Delete Confirmation Modal ────────────────────────────────────────── -->
<div id="delete-modal" class="modal-backdrop" style="display:none">
  <div class="modal-box">
    <div class="text-center">
      <div style="width:56px;height:56px;border-radius:14px;background:rgba(255,68,68,0.1);border:1px solid rgba(255,68,68,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 20px">
        <i data-lucide="trash-2" class="w-7 h-7" style="color:var(--danger)"></i>
      </div>
      <h3 style="font-size:18px;font-weight:700;margin-bottom:8px">Delete Subscription?</h3>
      <p style="color:var(--muted);font-size:13px;margin-bottom:20px">
        This action cannot be undone. The subscription and all its data will be permanently removed.
      </p>
      <div style="display:flex;gap:10px">
        <button id="cancel-delete" class="btn-ghost" style="flex:1;justify-content:center">Cancel</button>
        <button id="confirm-delete" class="btn-danger" style="flex:1;justify-content:center">
          <i data-lucide="trash-2" class="w-4 h-4"></i> Delete
        </button>
      </div>
    </div>
  </div>
</div>
