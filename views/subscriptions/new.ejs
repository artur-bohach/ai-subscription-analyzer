<%
  const today = formatDateInput(new Date());

  const categories = [
    'Entertainment', 'Productivity', 'Education',
    'Cloud & Storage', 'Music & Audio', 'AI Tools',
    'Health & Fitness', 'News & Media', 'Other'
  ];
  const currencies  = ['EUR', 'USD', 'GBP', 'JPY', 'CHF', 'CAD', 'AUD'];
  const cycles      = ['monthly', 'yearly', 'weekly'];
  const statuses    = ['active', 'paused', 'cancelled'];
%>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <!-- Back -->
  <div class="mb-6">
    <a href="/subscriptions" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-300 transition-colors">
      <i data-lucide="arrow-left" class="w-4 h-4"></i>
      Back to Subscriptions
    </a>
  </div>

  <!-- Page Title -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white flex items-center gap-2">
      <i data-lucide="plus-circle" class="w-6 h-6 text-purple-400"></i>
      Add New Subscription
    </h1>
    <p class="text-slate-500 text-sm mt-1">Fill in the details of your subscription below.</p>
  </div>

  <!-- Server-side Errors -->
  <% if (errors && errors.length > 0) { %>
    <div class="glass border border-red-500/30 rounded-xl p-4 mb-6 flex gap-3">
      <i data-lucide="alert-circle" class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5"></i>
      <div>
        <p class="text-sm font-semibold text-red-400 mb-1">Please fix the following errors:</p>
        <ul class="space-y-1 text-sm text-red-300 list-disc list-inside">
          <% errors.forEach(e => { %><li><%= e %></li><% }) %>
        </ul>
      </div>
    </div>
  <% } %>

  <!-- Form Card -->
  <div class="glass rounded-2xl p-8">
    <form id="subscription-form" action="/subscriptions" method="POST" novalidate>

      <!-- Name -->
      <div class="mb-5">
        <label for="name" class="form-label">Service Name <span class="text-red-400">*</span></label>
        <input
          id="name" name="name" type="text"
          class="form-input"
          placeholder="e.g. Netflix, Spotify, GitHub Copilot"
          value="<%= formData.name || '' %>"
          required
        />
      </div>

      <!-- Category + Currency row -->
      <div class="grid sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label for="category" class="form-label">Category <span class="text-red-400">*</span></label>
          <select id="category" name="category" class="form-input" required>
            <option value="">— Select category —</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= formData.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label for="currency" class="form-label">Currency</label>
          <select id="currency" name="currency" class="form-input">
            <% currencies.forEach(cur => { %>
              <option value="<%= cur %>" <%= (formData.currency || 'EUR') === cur ? 'selected' : '' %>><%= cur %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <!-- Cost + Billing Cycle row -->
      <div class="grid sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label for="cost" class="form-label">Cost <span class="text-red-400">*</span></label>
          <input
            id="cost" name="cost" type="number"
            class="form-input"
            placeholder="9.99"
            min="0.01" step="0.01"
            value="<%= formData.cost || '' %>"
            required
          />
        </div>
        <div>
          <label for="billingCycle" class="form-label">Billing Cycle <span class="text-red-400">*</span></label>
          <select id="billingCycle" name="billingCycle" class="form-input" required>
            <option value="">— Select cycle —</option>
            <% cycles.forEach(c => { %>
              <option value="<%= c %>" <%= formData.billingCycle === c ? 'selected' : '' %> class="capitalize"><%= c %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <!-- Start Date + Status row -->
      <div class="grid sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label for="startDate" class="form-label">Start Date <span class="text-red-400">*</span></label>
          <input
            id="startDate" name="startDate" type="date"
            class="form-input"
            value="<%= formData.startDate ? formatDateInput(formData.startDate) : today %>"
            required
          />
        </div>
        <div>
          <label for="status" class="form-label">Status</label>
          <select id="status" name="status" class="form-input">
            <% statuses.forEach(s => { %>
              <option value="<%= s %>" <%= (formData.status || 'active') === s ? 'selected' : '' %> class="capitalize"><%= s %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <!-- Notes -->
      <div class="mb-8">
        <label for="notes" class="form-label">Notes <span class="text-slate-600">(optional)</span></label>
        <textarea
          id="notes" name="notes"
          rows="3"
          class="form-input resize-none"
          placeholder="Any notes about this subscription..."
        ><%= formData.notes || '' %></textarea>
      </div>

      <!-- Submit -->
      <div class="flex gap-4">
        <button type="submit" class="btn-gradient flex-1 justify-center py-3">
          <i data-lucide="save" class="w-4 h-4"></i>
          Save Subscription
        </button>
        <a href="/subscriptions" class="btn-ghost py-3 px-6">
          Cancel
        </a>
      </div>
    </form>
  </div>
</div>
