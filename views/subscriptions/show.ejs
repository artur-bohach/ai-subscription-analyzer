
<div class="page-wrap">

  <!-- ── Card ──────────────────────────────────────────────────────────── -->
  <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-card);overflow:hidden;">

    <!-- Card Header -->
    <div style="padding:32px;border-bottom:1px solid var(--border);">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="service-icon flex-shrink-0" style="width:56px;height:56px;border-radius:12px;font-size:24px;">
          <i data-lucide="<%= getCategoryIcon(subscription.category) %>"></i>
        </div>
        <div class="flex-1">
          <div class="flex flex-wrap items-center gap-3 mb-1">
            <h1 class="text-2xl font-extrabold text-white"><%= subscription.name %></h1>
            <span class="status-badge status-<%= subscription.status %>">
              <span class="status-dot"></span>
              <%= subscription.status %>
            </span>
          </div>
          <p style="color:var(--muted);font-size:13px;">
            <i data-lucide="tag" class="w-3.5 h-3.5 inline-block mr-1"></i>
            <span class="cat-badge"><%= subscription.category %></span>
          </p>
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-3 flex-wrap">
          <a href="/subscriptions/<%= subscription.id %>/edit" class="btn-ghost" style="font-size:13px;padding:7px 16px;">
            <i data-lucide="pencil" class="w-4 h-4"></i>
            Edit
          </a>
          <button
            type="button"
            data-delete-form="delete-form-<%= subscription.id %>"
            class="btn-danger"
            style="padding:7px 16px;"
          >
            <i data-lucide="trash-2" class="w-4 h-4"></i>
            Delete
          </button>
          <form
            id="delete-form-<%= subscription.id %>"
            action="/subscriptions/<%= subscription.id %>?_method=DELETE"
            method="POST"
            style="display:none;"
          ></form>
        </div>
      </div>
    </div>

    <!-- Card Body -->
    <div style="padding:32px;">

      <!-- Cost Summary -->
      <div class="grid sm:grid-cols-3 gap-4" style="margin-bottom:32px;">
        <div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:20px;text-align:center;">
          <p style="font-size:11px;color:var(--muted2);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:8px;">Billed</p>
          <p style="font-size:22px;font-weight:800;color:var(--text);">
            <%= formatCurrency(Number(subscription.cost), subscription.currency) %>
          </p>
          <p style="font-size:11px;color:var(--muted2);margin-top:4px;text-transform:capitalize;"><%= subscription.billingCycle %></p>
        </div>
        <div style="background:rgba(0,255,135,0.05);border:1px solid rgba(0,255,135,0.15);border-radius:10px;padding:20px;text-align:center;">
          <p style="font-size:11px;color:var(--neon);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:8px;">Monthly Cost</p>
          <p style="font-size:22px;font-weight:800;color:var(--neon);">€<%= monthlyEquivalent %></p>
          <p style="font-size:11px;color:var(--muted2);margin-top:4px;">normalized</p>
        </div>
        <div style="background:var(--bg);border:1px solid var(--border2);border-radius:10px;padding:20px;text-align:center;">
          <p style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:8px;">Yearly Cost</p>
          <p style="font-size:22px;font-weight:800;color:var(--text);">€<%= yearlyEquivalent %></p>
          <p style="font-size:11px;color:var(--muted2);margin-top:4px;">projected</p>
        </div>
      </div>

      <!-- Details Grid -->
      <div class="grid sm:grid-cols-2 gap-5">

        <div class="space-y-5">
          <!-- Currency -->
          <div>
            <p style="font-size:11px;color:var(--muted2);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:4px;">Currency</p>
            <p class="text-white font-medium flex items-center gap-2">
              <i data-lucide="banknote" class="w-4 h-4" style="color:var(--muted2);"></i>
              <%= subscription.currency %>
            </p>
          </div>

          <!-- Billing Cycle -->
          <div>
            <p style="font-size:11px;color:var(--muted2);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:4px;">Billing Cycle</p>
            <p class="text-white font-medium capitalize flex items-center gap-2">
              <i data-lucide="repeat" class="w-4 h-4" style="color:var(--muted2);"></i>
              <%= subscription.billingCycle %>
            </p>
          </div>

          <!-- Start Date -->
          <div>
            <p style="font-size:11px;color:var(--muted2);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:4px;">Start Date</p>
            <p class="text-white font-medium flex items-center gap-2">
              <i data-lucide="calendar-plus" class="w-4 h-4" style="color:var(--muted2);"></i>
              <%= formatDateDisplay(subscription.startDate) %>
            </p>
          </div>
        </div>

        <div class="space-y-5">
          <!-- Next Payment -->
          <div>
            <p style="font-size:11px;color:var(--muted2);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:4px;">Next Payment</p>
            <p class="text-white font-medium flex items-center gap-2">
              <i data-lucide="calendar-clock" class="w-4 h-4" style="color:var(--muted2);"></i>
              <% if (subscription.nextPayment) { %>
                <%= formatDateDisplay(subscription.nextPayment) %>
              <% } else { %>
                —
              <% } %>
            </p>
          </div>

          <!-- Added -->
          <div>
            <p style="font-size:11px;color:var(--muted2);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:4px;">Added</p>
            <p class="text-white font-medium flex items-center gap-2">
              <i data-lucide="clock" class="w-4 h-4" style="color:var(--muted2);"></i>
              <%= formatDateDisplay(subscription.createdAt) %>
            </p>
          </div>

          <!-- Updated -->
          <div>
            <p style="font-size:11px;color:var(--muted2);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:4px;">Last Updated</p>
            <p class="text-white font-medium flex items-center gap-2">
              <i data-lucide="refresh-cw" class="w-4 h-4" style="color:var(--muted2);"></i>
              <%= formatDateDisplay(subscription.updatedAt) %>
            </p>
          </div>
        </div>
      </div>

      <!-- Notes -->
      <% if (subscription.notes) { %>
        <div style="margin-top:24px;padding-top:24px;border-top:1px solid var(--border);">
          <p style="font-size:11px;color:var(--muted2);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:8px;">Notes</p>
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:16px;">
            <p style="color:var(--muted);font-size:14px;line-height:1.6;"><%= subscription.notes %></p>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- ── Back to List ─────────────────────────────────────────────────────── -->
  <div style="margin-top:16px;">
    <a href="/subscriptions" class="btn-ghost" style="font-size:13px;padding:7px 16px;">
      <i data-lucide="arrow-left" class="w-4 h-4"></i>
      Back to List
    </a>
  </div>
</div>

<!-- ── Delete Confirmation Modal ─────────────────────────────────────────── -->
<div id="delete-modal" class="modal-backdrop" style="display:none;">
  <div class="modal-box">
    <div class="text-center">
      <div style="width:56px;height:56px;border-radius:12px;background:rgba(255,68,68,0.1);border:1px solid rgba(255,68,68,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
        <i data-lucide="trash-2" style="width:28px;height:28px;color:var(--danger);"></i>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">Delete "<%= subscription.name %>"?</h3>
      <p style="color:var(--muted);font-size:14px;margin-bottom:24px;">
        This action cannot be undone. The subscription and all its data will be permanently removed.
      </p>
      <div class="flex gap-3 justify-center">
        <button id="cancel-delete" class="btn-ghost" style="padding:10px 24px;flex:1;">Cancel</button>
        <button id="confirm-delete" class="btn-danger" style="padding:10px 24px;flex:1;justify-content:center;">
          <i data-lucide="trash-2" class="w-4 h-4"></i> Delete
        </button>
      </div>
    </div>
  </div>
</div>
