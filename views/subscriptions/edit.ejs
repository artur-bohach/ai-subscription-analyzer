<%
  const fe = fieldErrors || {};
  const data = (formData && 'name' in formData) ? formData : subscription;

  const categories = [
    'Entertainment', 'Productivity', 'Education',
    'Cloud & Storage', 'Music & Audio', 'AI Tools',
    'Health & Fitness', 'News & Media', 'Other',
  ];
  const currencies = ['EUR', 'USD', 'GBP', 'JPY', 'CHF', 'CAD', 'AUD'];
  const cycles     = ['monthly', 'yearly', 'weekly'];
  const statuses   = ['active', 'paused', 'cancelled'];

  const errorCount = Object.keys(fe).length;

  const costDisplay = (() => {
    const c = data.cost;
    if (c == null || c === '') return '';
    const n = Number(c);
    return isNaN(n) ? String(c) : n.toFixed(2);
  })();
%>

<div class="page-wrap" style="max-width:680px;">

  <!-- Page Title -->
  <div style="margin-bottom:32px;">
    <div class="page-header-row">
      <div>
        <h1 class="page-title">Edit Subscription</h1>
        <p class="page-sub">Update the details for <strong style="color:var(--text);"><%= subscription.name %></strong>.</p>
      </div>
    </div>
  </div>

  <!-- Server-side error summary banner -->
  <% if (errorCount > 0) { %>
    <div style="background:rgba(255,68,68,0.08);border:1px solid rgba(255,68,68,0.2);border-radius:10px;padding:16px;margin-bottom:24px;display:flex;gap:12px;" role="alert">
      <i data-lucide="alert-circle" style="width:20px;height:20px;color:var(--danger);flex-shrink:0;margin-top:2px;"></i>
      <p style="font-size:14px;font-weight:600;color:var(--danger);">
        Please fix <%= errorCount %> error<%= errorCount !== 1 ? 's' : '' %> below before continuing.
      </p>
    </div>
  <% } %>

  <!-- Form Card -->
  <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-card);padding:32px;">
    <form
      id="subscription-form"
      action="/subscriptions/<%= subscription.id %>?_method=PUT"
      method="POST"
      novalidate
    >

      <!-- Name -->
      <div class="mb-5">
        <label for="name" class="form-label">Service Name <span style="color:var(--danger);">*</span></label>
        <input
          id="name" name="name" type="text"
          class="form-input <%= fe.name ? 'is-error' : '' %>"
          placeholder="e.g. Netflix, Spotify, GitHub Copilot"
          value="<%= data.name || '' %>"
          required
        />
        <% if (fe.name) { %><p class="field-error-msg show">⚠ <%= fe.name %></p><% } %>
      </div>

      <!-- Category + Currency -->
      <div class="grid sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label for="category" class="form-label">Category <span style="color:var(--danger);">*</span></label>
          <select id="category" name="category" class="form-input <%= fe.category ? 'is-error' : '' %>" required>
            <option value="">— Select category —</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= data.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
          <% if (fe.category) { %><p class="field-error-msg show">⚠ <%= fe.category %></p><% } %>
        </div>
        <div>
          <label for="currency" class="form-label">Currency</label>
          <select id="currency" name="currency" class="form-input">
            <% currencies.forEach(cur => { %>
              <option value="<%= cur %>" <%= (data.currency || 'EUR') === cur ? 'selected' : '' %>><%= cur %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <!-- Cost + Billing Cycle -->
      <div class="grid sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label for="cost" class="form-label">Cost <span style="color:var(--danger);">*</span></label>
          <input
            id="cost" name="cost" type="number"
            class="form-input <%= fe.cost ? 'is-error' : '' %>"
            placeholder="9.99" min="0.01" step="0.01"
            value="<%= costDisplay %>"
            required
          />
          <% if (fe.cost) { %><p class="field-error-msg show">⚠ <%= fe.cost %></p><% } %>
        </div>
        <div>
          <label for="billingCycle" class="form-label">Billing Cycle <span style="color:var(--danger);">*</span></label>
          <select id="billingCycle" name="billingCycle" class="form-input <%= fe.billingCycle ? 'is-error' : '' %>" required>
            <option value="">— Select cycle —</option>
            <% cycles.forEach(c => { %>
              <option value="<%= c %>" <%= data.billingCycle === c ? 'selected' : '' %>><%= c %></option>
            <% }) %>
          </select>
          <% if (fe.billingCycle) { %><p class="field-error-msg show">⚠ <%= fe.billingCycle %></p><% } %>
        </div>
      </div>

      <!-- Start Date + Status -->
      <div class="grid sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label for="startDate" class="form-label">Start Date <span style="color:var(--danger);">*</span></label>
          <input
            id="startDate" name="startDate" type="date"
            class="form-input <%= fe.startDate ? 'is-error' : '' %>"
            value="<%= data.startDate ? formatDateInput(data.startDate) : '' %>"
            required
          />
          <% if (fe.startDate) { %><p class="field-error-msg show">⚠ <%= fe.startDate %></p><% } %>
        </div>
        <div>
          <label for="status" class="form-label">Status</label>
          <select id="status" name="status" class="form-input <%= fe.status ? 'is-error' : '' %>">
            <% statuses.forEach(s => { %>
              <option value="<%= s %>" <%= (data.status || 'active') === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
          <% if (fe.status) { %><p class="field-error-msg show">⚠ <%= fe.status %></p><% } %>
        </div>
      </div>

      <!-- Notes -->
      <div class="mb-8">
        <label for="notes" class="form-label">Notes <span style="color:var(--muted2);font-weight:400;">(optional)</span></label>
        <textarea
          id="notes" name="notes"
          rows="3"
          class="form-input resize-none <%= fe.notes ? 'is-error' : '' %>"
          placeholder="Any notes about this subscription…"
        ><%= data.notes || '' %></textarea>
        <% if (fe.notes) { %><p class="field-error-msg show">⚠ <%= fe.notes %></p><% } %>
      </div>

      <!-- Actions -->
      <div class="flex gap-4">
        <button type="submit" class="btn-primary flex-1 justify-center" style="padding:12px;">
          <i data-lucide="save" class="w-4 h-4"></i>
          Save Changes
        </button>
        <a href="/subscriptions/<%= subscription.id %>" class="btn-ghost" style="padding:12px 24px;">Cancel</a>
      </div>
    </form>
  </div>

  <!-- Danger Zone -->
  <div style="background:var(--card);border:1px solid rgba(255,68,68,0.15);border-radius:var(--radius-card);padding:24px;margin-top:24px;">
    <h3 style="font-size:13px;font-weight:600;color:var(--danger);margin-bottom:4px;display:flex;align-items:center;gap:8px;">
      <i data-lucide="alert-triangle" class="w-4 h-4"></i>
      Danger Zone
    </h3>
    <p style="font-size:12px;color:var(--muted2);margin-bottom:16px;">Permanently delete this subscription. This cannot be undone.</p>
    <button
      type="button"
      data-delete-form="delete-form-<%= subscription.id %>"
      class="btn-danger"
      style="padding:8px 16px;"
    >
      <i data-lucide="trash-2" class="w-4 h-4"></i>
      Delete Subscription
    </button>
    <form
      id="delete-form-<%= subscription.id %>"
      action="/subscriptions/<%= subscription.id %>?_method=DELETE"
      method="POST"
      style="display:none;"
    ></form>
  </div>
</div>

<!-- ── Delete Confirmation Modal ─────────────────────────────────────────── -->
<div id="delete-modal" class="modal-backdrop" style="display:none;">
  <div class="modal-box">
    <div class="text-center">
      <div style="width:56px;height:56px;border-radius:12px;background:rgba(255,68,68,0.1);border:1px solid rgba(255,68,68,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
        <i data-lucide="trash-2" style="width:28px;height:28px;color:var(--danger);"></i>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">Delete "<%= subscription.name %>"?</h3>
      <p style="color:var(--muted);font-size:14px;margin-bottom:24px;">
        This action cannot be undone. The subscription will be permanently deleted.
      </p>
      <div class="flex gap-3 justify-center">
        <button id="cancel-delete" class="btn-ghost" style="padding:10px 24px;flex:1;">Cancel</button>
        <button id="confirm-delete" class="btn-danger" style="padding:10px 24px;flex:1;justify-content:center;">
          <i data-lucide="trash-2" class="w-4 h-4"></i> Delete
        </button>
      </div>
    </div>
  </div>
</div>
