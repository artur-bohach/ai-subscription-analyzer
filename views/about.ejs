<!-- ── About Header ───────────────────────────────────────────────────────── -->
<section class="pt-16 pb-12 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <div style="display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:20px;background:var(--card);border:1px solid var(--border2);font-size:13px;color:var(--muted);font-weight:500;margin-bottom:24px;">
      <i data-lucide="info" class="w-4 h-4" style="color:var(--neon);"></i>
      About the Project
    </div>
    <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-5">
      Built for <span style="color:var(--neon);">financial clarity</span>
    </h1>
    <p style="font-size:18px;color:var(--muted);max-width:640px;margin:0 auto;line-height:1.7;">
      SubTracker is an open-source web application that helps you track,
      manage and optimize your recurring digital subscriptions — all in one clean, modern interface.
    </p>
  </div>
</section>

<!-- ── Tech Stack ─────────────────────────────────────────────────────────── -->
<section class="py-16 px-4">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-white text-center mb-10">
      <span style="color:var(--neon);">Technology</span> Stack
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <%
        const techs = [
          { icon: 'server',      name: 'Node.js + Express',  desc: 'Fast, minimalist web server' },
          { icon: 'file-code',   name: 'EJS Templates',      desc: 'Server-side rendering engine' },
          { icon: 'database',    name: 'PostgreSQL',          desc: 'Robust relational database' },
          { icon: 'layers',      name: 'Prisma ORM',         desc: 'Type-safe database client' },
          { icon: 'palette',     name: 'Tailwind CSS 4',     desc: 'Utility-first CSS framework' },
          { icon: 'code',        name: 'Vanilla JavaScript', desc: 'Interactive client-side logic' }
        ];
      %>
      <% techs.forEach(t => { %>
        <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-card);padding:20px;display:flex;align-items:flex-start;gap:16px;transition:border-color var(--transition);" onmouseover="this.style.borderColor='var(--border2)'" onmouseout="this.style.borderColor='var(--border)'">
          <div style="width:40px;height:40px;border-radius:8px;background:rgba(0,255,135,0.08);border:1px solid rgba(0,255,135,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i data-lucide="<%= t.icon %>" style="width:18px;height:18px;color:var(--neon);"></i>
          </div>
          <div>
            <h3 style="font-weight:600;color:var(--text);font-size:14px;margin-bottom:2px;"><%= t.name %></h3>
            <p style="font-size:12px;color:var(--muted2);"><%= t.desc %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ── Features List ──────────────────────────────────────────────────────── -->
<section class="py-16 px-4">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl font-bold text-white text-center mb-10">
      What's <span style="color:var(--neon);">Included</span>
    </h2>

    <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-card);padding:32px;">
      <%
        const features = [
          'Full CRUD for subscriptions (create, read, update, delete)',
          'Real-time monthly & yearly spending calculations',
          'Billing cycle normalization (weekly → monthly → yearly)',
          'Multi-currency support (EUR, USD, GBP and more)',
          'Category-based organization with icons',
          'Status tracking: active, paused, cancelled',
          'Next payment date auto-calculation',
          'Responsive monochrome UI with dark theme',
          'Client-side form validation',
          'Flash notifications for user feedback',
          'Session & authentication support',
          'PostgreSQL database with Prisma ORM',
          '404 & 500 error pages'
        ];
      %>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <% features.forEach(f => { %>
          <div style="display:flex;align-items:center;gap:12px;color:var(--muted);font-size:14px;">
            <i data-lucide="check-circle-2" style="width:16px;height:16px;color:var(--neon);flex-shrink:0;"></i>
            <%= f %>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<!-- ── FAQ ────────────────────────────────────────────────────────────────── -->
<section class="py-16 px-4">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl font-bold text-white text-center mb-10">
      Frequently Asked <span style="color:var(--neon);">Questions</span>
    </h2>

    <div class="space-y-3">
      <%
        const faqs = [
          {
            q: 'Is my subscription data stored securely?',
            a: 'Yes. All data is stored in a private PostgreSQL database. The application runs on your own infrastructure — no data is sent to third-party services.'
          },
          {
            q: 'Can I track subscriptions in different currencies?',
            a: 'Absolutely. Each subscription can have its own currency (EUR, USD, GBP, JPY, etc.). The summary totals use the stored values as-is — currency conversion is a planned enhancement.'
          },
          {
            q: 'How is the monthly cost calculated for yearly plans?',
            a: 'Yearly costs are divided by 12 to get a monthly equivalent. Weekly costs are multiplied by 4.33 (average weeks per month). This gives you a normalized view of all your spending.'
          },
          {
            q: 'Can multiple users share the application?',
            a: 'Yes. The app supports full multi-user authentication with role-based access control (admin / regular user).'
          },
          {
            q: 'How do I add test data to the database?',
            a: 'Run `node seed.js` after setting up the database. It will create an admin user (admin/admin123) and 10 sample subscriptions across different categories.'
          }
        ];
      %>
      <% faqs.forEach((faq, i) => { %>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            <span><%= faq.q %></span>
            <i data-lucide="chevron-down" class="w-5 h-5 faq-arrow flex-shrink-0 ml-4"></i>
          </button>
          <div class="faq-answer">
            <%= faq.a %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
