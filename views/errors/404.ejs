<style>
  @keyframes err-float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-22px); }
  }
  @keyframes err-orbit {
    from { transform: rotate(0deg) translateX(52px) rotate(0deg); }
    to   { transform: rotate(360deg) translateX(52px) rotate(-360deg); }
  }
  @keyframes err-twinkle {
    0%, 100% { opacity: 0.9; transform: scale(1); }
    50%      { opacity: 0.15; transform: scale(0.4); }
  }
  @keyframes err-glow-neon {
    0%, 100% { box-shadow: 0 0 24px rgba(0,255,135,0.25); }
    50%      { box-shadow: 0 0 55px rgba(0,255,135,0.5); }
  }
</style>

<section class="relative min-h-[calc(100vh-8rem)] flex items-center justify-center px-4 overflow-hidden">

  <!-- Background stars -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
    <span class="absolute w-1 h-1 rounded-full bg-white/30"
          style="top:10%; left:12%; animation: err-twinkle 2.1s ease-in-out infinite 0.0s;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full" style="background:var(--neon);opacity:0.4;top:22%; left:74%; animation: err-twinkle 1.7s ease-in-out infinite 0.4s;"></span>
    <span class="absolute w-1 h-1 rounded-full bg-white/20"
          style="top:58%; left:6%;  animation: err-twinkle 2.5s ease-in-out infinite 0.8s;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full bg-white/30"
          style="top:72%; left:87%; animation: err-twinkle 1.9s ease-in-out infinite 0.2s;"></span>
    <span class="absolute w-1 h-1 rounded-full" style="background:var(--neon);opacity:0.2;top:38%; left:92%; animation: err-twinkle 2.3s ease-in-out infinite 1.1s;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full bg-white/30"
          style="top:84%; left:34%; animation: err-twinkle 1.5s ease-in-out infinite 0.6s;"></span>
    <span class="absolute w-1 h-1 rounded-full bg-white/20"
          style="top:16%; left:52%; animation: err-twinkle 2.8s ease-in-out infinite 0.9s;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full" style="background:var(--neon);opacity:0.3;top:48%; left:43%; animation: err-twinkle 2.0s ease-in-out infinite 1.4s;"></span>
    <span class="absolute w-1 h-1 rounded-full bg-white/25"
          style="top:66%; left:60%; animation: err-twinkle 2.4s ease-in-out infinite 0.3s;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full bg-white/20"
          style="top:30%; left:28%; animation: err-twinkle 1.8s ease-in-out infinite 1.2s;"></span>
  </div>

  <div class="relative z-10 text-center max-w-lg mx-auto">

    <!-- Hero: "404" + floating orb -->
    <div class="relative inline-block mb-6">

      <!-- Giant "404" -->
      <h1 style="font-size:clamp(7rem,15vw,13rem);font-weight:900;line-height:1;color:var(--neon);user-select:none;">
        404
      </h1>

      <!-- Floating orb -->
      <div class="absolute -top-6 -right-6 sm:-right-2"
           style="animation: err-float 4s ease-in-out infinite;">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-32 h-32 rounded-full"
             style="border: 1px dashed rgba(0,255,135,0.2);"></div>
        <div class="absolute w-3 h-3 rounded-full"
             style="background:var(--neon);top: calc(50% - 6px); left: calc(50% - 6px);
                    animation: err-orbit 7s linear infinite;
                    box-shadow: 0 0 10px var(--neon);"></div>
        <div style="position:relative;width:84px;height:84px;border-radius:20px;display:flex;align-items:center;justify-content:center;background:rgba(0,255,135,0.08);border:1px solid rgba(0,255,135,0.2);animation: err-glow-neon 3s ease-in-out infinite;">
          <i data-lucide="search-x" style="width:36px;height:36px;color:var(--neon);"></i>
        </div>
      </div>
    </div>

    <!-- Info card -->
    <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-card);padding:32px;margin-bottom:32px;">
      <h2 class="text-2xl font-bold text-white mb-3">Page Not Found</h2>
      <p style="color:var(--muted);line-height:1.6;">
        Looks like this page drifted into the void.
        <% if (locals.message) { %>
          <span style="display:block;margin-top:8px;font-size:13px;color:var(--muted2);"><%= message %></span>
        <% } %>
      </p>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/" class="btn-primary" style="padding:10px 32px;">
        <i data-lucide="home" class="w-4 h-4"></i>
        Back to Home
      </a>
      <a href="/subscriptions" class="btn-ghost" style="padding:10px 32px;">
        <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
        Dashboard
      </a>
    </div>

  </div>
</section>
