<style>
  @keyframes err-float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-22px); }
  }
  @keyframes err-orbit {
    from { transform: rotate(0deg) translateX(52px) rotate(0deg); }
    to   { transform: rotate(360deg) translateX(52px) rotate(-360deg); }
  }
  @keyframes err-twinkle {
    0%, 100% { opacity: 0.9; transform: scale(1); }
    50%      { opacity: 0.15; transform: scale(0.4); }
  }
  @keyframes err-glow-purple {
    0%, 100% { box-shadow: 0 0 24px rgba(139,92,246,0.35); }
    50%      { box-shadow: 0 0 55px rgba(139,92,246,0.65); }
  }
</style>

<section class="relative min-h-[calc(100vh-8rem)] flex items-center justify-center px-4 overflow-hidden">

  <!-- Background stars -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
    <span class="absolute w-1 h-1 rounded-full bg-white"
          style="top:10%; left:12%; animation: err-twinkle 2.1s ease-in-out infinite 0.0s;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full bg-purple-300"
          style="top:22%; left:74%; animation: err-twinkle 1.7s ease-in-out infinite 0.4s;"></span>
    <span class="absolute w-1 h-1 rounded-full bg-blue-200"
          style="top:58%; left:6%;  animation: err-twinkle 2.5s ease-in-out infinite 0.8s;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full bg-white"
          style="top:72%; left:87%; animation: err-twinkle 1.9s ease-in-out infinite 0.2s;"></span>
    <span class="absolute w-1 h-1 rounded-full bg-purple-200"
          style="top:38%; left:92%; animation: err-twinkle 2.3s ease-in-out infinite 1.1s;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full bg-white"
          style="top:84%; left:34%; animation: err-twinkle 1.5s ease-in-out infinite 0.6s;"></span>
    <span class="absolute w-1 h-1 rounded-full bg-blue-300"
          style="top:16%; left:52%; animation: err-twinkle 2.8s ease-in-out infinite 0.9s;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full bg-purple-400"
          style="top:48%; left:43%; animation: err-twinkle 2.0s ease-in-out infinite 1.4s;"></span>
    <span class="absolute w-1 h-1 rounded-full bg-white"
          style="top:66%; left:60%; animation: err-twinkle 2.4s ease-in-out infinite 0.3s;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full bg-blue-200"
          style="top:30%; left:28%; animation: err-twinkle 1.8s ease-in-out infinite 1.2s;"></span>
  </div>

  <div class="relative z-10 text-center max-w-lg mx-auto">

    <!-- Hero: "404" + floating orb -->
    <div class="relative inline-block mb-6">

      <!-- Giant gradient "404" -->
      <h1 class="text-[10rem] sm:text-[13rem] font-black leading-none gradient-text select-none">
        404
      </h1>

      <!-- Floating orb, anchored to top-right of the number -->
      <div class="absolute -top-6 -right-6 sm:-right-2"
           style="animation: err-float 4s ease-in-out infinite;">
        <!-- Dashed orbit ring -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-32 h-32 rounded-full"
             style="border: 1px dashed rgba(139,92,246,0.25);"></div>
        <!-- Orbiting mini planet -->
        <div class="absolute w-3 h-3 rounded-full bg-purple-400"
             style="top: calc(50% - 6px); left: calc(50% - 6px);
                    animation: err-orbit 7s linear infinite;
                    box-shadow: 0 0 10px rgba(139,92,246,0.9);"></div>
        <!-- Main glass orb -->
        <div class="relative glass w-[84px] h-[84px] rounded-[20px] flex items-center justify-center border border-purple-500/30"
             style="animation: err-glow-purple 3s ease-in-out infinite;">
          <i data-lucide="search-x" class="w-9 h-9 text-purple-400"></i>
        </div>
      </div>
    </div>

    <!-- Info card -->
    <div class="glass rounded-2xl p-8 mb-8">
      <h2 class="text-2xl font-bold text-white mb-3">Page Not Found</h2>
      <p class="text-slate-400 leading-relaxed">
        Looks like this page drifted into the void.
        <% if (locals.message) { %>
          <span class="block mt-2 text-sm text-slate-500"><%= message %></span>
        <% } %>
      </p>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/" class="btn-gradient px-8 py-2.5">
        <i data-lucide="home" class="w-4 h-4"></i>
        Back to Home
      </a>
      <a href="/subscriptions" class="btn-ghost px-8 py-2.5">
        <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
        Dashboard
      </a>
    </div>

  </div>
</section>
