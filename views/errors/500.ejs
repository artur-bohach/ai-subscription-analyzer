<style>
  @keyframes err500-float {
    0%, 100% { transform: translateY(0px) rotate(-1deg); }
    50%       { transform: translateY(-18px) rotate(1deg); }
  }
  @keyframes err500-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @keyframes err500-spin-r {
    from { transform: rotate(0deg); }
    to   { transform: rotate(-360deg); }
  }
  @keyframes err500-glow-red {
    0%, 100% { box-shadow: 0 0 22px rgba(239,68,68,0.30); }
    50%      { box-shadow: 0 0 55px rgba(239,68,68,0.60); }
  }
  @keyframes err500-glitch {
    0%,  87%, 100% { clip-path: none; transform: none; }
    88%  { clip-path: polygon(0 0, 100% 0, 100% 33%, 0 33%); transform: translateX(-5px); }
    90%  { clip-path: polygon(0 60%, 100% 60%, 100% 100%, 0 100%); transform: translateX(5px); }
    92%  { clip-path: none; transform: translateX(-2px); }
    94%  { clip-path: none; transform: none; }
  }
</style>

<section class="relative min-h-[calc(100vh-8rem)] flex items-center justify-center px-4 overflow-hidden">

  <!-- Decorative spinning rings -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
    <div class="absolute top-1/4 -left-16 w-52 h-52 rounded-full"
         style="border: 1px solid rgba(239,68,68,0.07); animation: err500-spin 20s linear infinite;"></div>
    <div class="absolute bottom-1/4 -right-16 w-44 h-44 rounded-full"
         style="border: 1px solid rgba(245,158,11,0.07); animation: err500-spin-r 14s linear infinite;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[480px] h-[480px] rounded-full"
         style="border: 1px solid rgba(239,68,68,0.04); animation: err500-spin 35s linear infinite;"></div>
    <!-- Scattered particles -->
    <span class="absolute w-1 h-1 rounded-full bg-red-400/40"    style="top:14%; left:9%;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full bg-amber-300/50" style="top:28%; left:82%;"></span>
    <span class="absolute w-1 h-1 rounded-full bg-orange-400/35"  style="top:62%; left:14%;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full bg-red-300/50"  style="top:77%; left:89%;"></span>
    <span class="absolute w-1 h-1 rounded-full bg-amber-400/35"   style="top:44%; left:93%;"></span>
  </div>

  <div class="relative z-10 text-center max-w-lg mx-auto">

    <!-- Hero: "500" + floating orb -->
    <div class="relative inline-block mb-6">

      <!-- Giant "500" with glitch effect -->
      <h1 class="text-[10rem] sm:text-[13rem] font-black leading-none select-none"
          style="background: linear-gradient(135deg, #fb923c 0%, #ef4444 50%, #dc2626 100%);
                 -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
                 animation: err500-glitch 6s ease-in-out infinite;">
        500
      </h1>

      <!-- Floating orb -->
      <div class="absolute -top-6 -right-6 sm:-right-2"
           style="animation: err500-float 3.5s ease-in-out infinite;">
        <!-- Spinning dashed orbit ring -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-32 h-32 rounded-full"
             style="border: 1px dashed rgba(239,68,68,0.25); animation: err500-spin 10s linear infinite;"></div>
        <!-- Main orb -->
        <div class="relative w-[84px] h-[84px] rounded-[20px] flex items-center justify-center border border-red-500/30"
             style="background: rgba(239,68,68,0.08); animation: err500-glow-red 2.5s ease-in-out infinite;">
          <i data-lucide="server-crash" class="w-9 h-9 text-red-400"></i>
        </div>
      </div>
    </div>

    <!-- Info card -->
    <div class="glass rounded-2xl p-8 mb-8 border border-red-500/10">
      <h2 class="text-2xl font-bold text-white mb-3">Something Went Wrong</h2>
      <p class="text-slate-400 leading-relaxed">
        Our servers hit an unexpected snag. Your data is safe — please try again.
      </p>

      <% if (locals.stack) { %>
        <!-- Dev-only: stack trace, hidden in production -->
        <details class="mt-5 text-left">
          <summary class="cursor-pointer text-xs text-slate-500 hover:text-slate-400 transition-colors select-none inline-flex items-center gap-1.5">
            <i data-lucide="bug" class="w-3 h-3"></i>
            Developer details (not shown in production)
          </summary>
          <div class="mt-3 p-4 rounded-xl bg-black/40 border border-white/5 overflow-auto max-h-56">
            <% if (locals.errorMessage) { %>
              <p class="text-xs font-mono text-amber-400 mb-3 pb-2 border-b border-white/5 break-all"><%= errorMessage %></p>
            <% } %>
            <pre class="text-xs text-slate-500 font-mono whitespace-pre-wrap break-words"><%= stack %></pre>
          </div>
        </details>
      <% } %>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <button onclick="window.location.reload()" class="btn-gradient px-8 py-2.5">
        <i data-lucide="refresh-cw" class="w-4 h-4"></i>
        Try Again
      </button>
      <a href="/" class="btn-ghost px-8 py-2.5">
        <i data-lucide="home" class="w-4 h-4"></i>
        Back to Home
      </a>
    </div>

  </div>
</section>
