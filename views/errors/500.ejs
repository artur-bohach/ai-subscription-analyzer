<style>
  @keyframes err500-float {
    0%, 100% { transform: translateY(0px) rotate(-1deg); }
    50%       { transform: translateY(-18px) rotate(1deg); }
  }
  @keyframes err500-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @keyframes err500-spin-r {
    from { transform: rotate(0deg); }
    to   { transform: rotate(-360deg); }
  }
  @keyframes err500-glow-red {
    0%, 100% { box-shadow: 0 0 22px rgba(255,68,68,0.30); }
    50%      { box-shadow: 0 0 55px rgba(255,68,68,0.60); }
  }
  @keyframes err500-glitch {
    0%,  87%, 100% { clip-path: none; transform: none; }
    88%  { clip-path: polygon(0 0, 100% 0, 100% 33%, 0 33%); transform: translateX(-5px); }
    90%  { clip-path: polygon(0 60%, 100% 60%, 100% 100%, 0 100%); transform: translateX(5px); }
    92%  { clip-path: none; transform: translateX(-2px); }
    94%  { clip-path: none; transform: none; }
  }
</style>

<section class="relative min-h-[calc(100vh-8rem)] flex items-center justify-center px-4 overflow-hidden">

  <!-- Decorative spinning rings -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
    <div class="absolute top-1/4 -left-16 w-52 h-52 rounded-full"
         style="border: 1px solid rgba(255,68,68,0.07); animation: err500-spin 20s linear infinite;"></div>
    <div class="absolute bottom-1/4 -right-16 w-44 h-44 rounded-full"
         style="border: 1px solid rgba(255,184,0,0.07); animation: err500-spin-r 14s linear infinite;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[480px] h-[480px] rounded-full"
         style="border: 1px solid rgba(255,68,68,0.04); animation: err500-spin 35s linear infinite;"></div>
    <span class="absolute w-1 h-1 rounded-full" style="background:rgba(255,68,68,0.4);top:14%;left:9%;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full" style="background:rgba(255,184,0,0.5);top:28%;left:82%;"></span>
    <span class="absolute w-1 h-1 rounded-full" style="background:rgba(255,68,68,0.35);top:62%;left:14%;"></span>
    <span class="absolute w-0.5 h-0.5 rounded-full" style="background:rgba(255,68,68,0.5);top:77%;left:89%;"></span>
    <span class="absolute w-1 h-1 rounded-full" style="background:rgba(255,184,0,0.35);top:44%;left:93%;"></span>
  </div>

  <div class="relative z-10 text-center max-w-lg mx-auto">

    <!-- Hero: "500" + floating orb -->
    <div class="relative inline-block mb-6">

      <!-- Giant "500" with glitch effect -->
      <h1 style="font-size:clamp(7rem,15vw,13rem);font-weight:900;line-height:1;user-select:none;
                 color:var(--danger);animation: err500-glitch 6s ease-in-out infinite;">
        500
      </h1>

      <!-- Floating orb -->
      <div class="absolute -top-6 -right-6 sm:-right-2"
           style="animation: err500-float 3.5s ease-in-out infinite;">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-32 h-32 rounded-full"
             style="border: 1px dashed rgba(255,68,68,0.25); animation: err500-spin 10s linear infinite;"></div>
        <div style="position:relative;width:84px;height:84px;border-radius:20px;display:flex;align-items:center;justify-content:center;background:rgba(255,68,68,0.08);border:1px solid rgba(255,68,68,0.2);animation: err500-glow-red 2.5s ease-in-out infinite;">
          <i data-lucide="server-crash" style="width:36px;height:36px;color:var(--danger);"></i>
        </div>
      </div>
    </div>

    <!-- Info card -->
    <div style="background:var(--card);border:1px solid rgba(255,68,68,0.15);border-radius:var(--radius-card);padding:32px;margin-bottom:32px;">
      <h2 class="text-2xl font-bold text-white mb-3">Something Went Wrong</h2>
      <p style="color:var(--muted);line-height:1.6;">
        Our servers hit an unexpected snag. Your data is safe — please try again.
      </p>

      <% if (locals.stack) { %>
        <details class="mt-5 text-left">
          <summary style="cursor:pointer;font-size:12px;color:var(--muted2);display:inline-flex;align-items:center;gap:6px;user-select:none;">
            <i data-lucide="bug" class="w-3 h-3"></i>
            Developer details (not shown in production)
          </summary>
          <div style="margin-top:12px;padding:16px;border-radius:8px;background:#000;border:1px solid var(--border);overflow:auto;max-height:224px;">
            <% if (locals.errorMessage) { %>
              <p style="font-size:12px;font-family:monospace;color:var(--warn);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border);word-break:break-all;"><%= errorMessage %></p>
            <% } %>
            <pre style="font-size:12px;color:var(--muted2);font-family:monospace;white-space:pre-wrap;word-break:break-word;"><%= stack %></pre>
          </div>
        </details>
      <% } %>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <button onclick="window.location.reload()" class="btn-primary" style="padding:10px 32px;">
        <i data-lucide="refresh-cw" class="w-4 h-4"></i>
        Try Again
      </button>
      <a href="/" class="btn-ghost" style="padding:10px 32px;">
        <i data-lucide="home" class="w-4 h-4"></i>
        Back to Home
      </a>
    </div>

  </div>
</section>
