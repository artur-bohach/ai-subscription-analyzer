<!-- ── Login Page (FR5 stub) ───────────────────────────────────────────────── -->
<section class="min-h-[calc(100vh-8rem)] flex items-center justify-center px-4 py-16">
  <div class="w-full max-w-md">

    <!-- Logo / Brand -->
    <div class="text-center mb-8">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-purple-500 to-blue-500 flex items-center justify-center mx-auto mb-5 shadow-lg shadow-purple-500/30">
        <i data-lucide="layers" class="w-8 h-8 text-white"></i>
      </div>
      <h1 class="text-3xl font-extrabold text-white">Welcome back</h1>
      <p class="text-slate-400 mt-2 text-sm">Sign in to SubTracker</p>
    </div>

    <!-- Login Card -->
    <div class="glass p-8 rounded-2xl">
      <form action="/login" method="POST" novalidate>

        <!-- Username -->
        <div class="mb-5">
          <label for="username" class="form-label">
            <i data-lucide="user" class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5"></i>
            Username
          </label>
          <input
            id="username"
            name="username"
            type="text"
            class="form-input"
            placeholder="admin"
            autocomplete="username"
            required
          />
        </div>

        <!-- Password -->
        <div class="mb-6">
          <label for="password" class="form-label">
            <i data-lucide="lock" class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5"></i>
            Password
          </label>
          <input
            id="password"
            name="password"
            type="password"
            class="form-input"
            placeholder="••••••••"
            autocomplete="current-password"
            required
          />
        </div>

        <button type="submit" class="btn-gradient w-full justify-center py-3 text-base">
          <i data-lucide="log-in" class="w-5 h-5"></i>
          Sign In
        </button>
      </form>

      <!-- Demo credentials hint -->
      <div class="mt-6 p-4 rounded-xl bg-purple-500/10 border border-purple-500/20">
        <p class="text-xs text-purple-300 text-center font-medium mb-1">
          <i data-lucide="info" class="w-3.5 h-3.5 inline-block mr-1"></i>
          Demo Credentials
        </p>
        <div class="flex justify-center gap-6 text-xs text-slate-400">
          <span>Username: <code class="text-purple-300 font-mono">admin</code></span>
          <span>Password: <code class="text-purple-300 font-mono">admin123</code></span>
        </div>
      </div>
    </div>

    <p class="text-center text-xs text-slate-600 mt-6">
      Authentication is a placeholder for FR5. Full session management coming soon.
    </p>
  </div>
</section>
