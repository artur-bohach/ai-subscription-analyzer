<section class="auth-page">
  <div class="auth-card-wrap">

    <!-- Logo / Brand -->
    <div class="auth-logo">
      <div class="auth-logo-icon">S</div>
      <h1>Welcome back</h1>
      <p>Sign in to SubTracker</p>
    </div>

    <!-- Login Card -->
    <div class="auth-card">
      <form action="/login" method="POST" novalidate>

        <!-- Username -->
        <div class="pf-field">
          <label for="username" class="form-label">
            <i data-lucide="user" class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5"></i>
            Username
          </label>
          <input
            id="username"
            name="username"
            type="text"
            class="form-input"
            placeholder="admin"
            autocomplete="username"
            required
          />
        </div>

        <!-- Password -->
        <div class="pf-field">
          <label for="password" class="form-label">
            <i data-lucide="lock" class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5"></i>
            Password
          </label>
          <input
            id="password"
            name="password"
            type="password"
            class="form-input"
            placeholder="••••••••"
            autocomplete="current-password"
            required
          />
        </div>

        <button type="submit" class="btn-primary w-full justify-center" style="font-size:15px;padding:11px">
          <i data-lucide="log-in" class="w-5 h-5"></i>
          Sign In
        </button>
      </form>

      <!-- Demo hint -->
      <div class="auth-hint">
        <i data-lucide="info" class="w-3.5 h-3.5" style="color:var(--neon);flex-shrink:0"></i>
        <span>Demo: <code>admin</code> / <code>admin123</code></span>
      </div>
    </div>

    <p class="text-center" style="font-size:12px;color:var(--muted2);margin-top:20px">
      Don't have an account? <a href="/register" style="color:var(--neon);text-decoration:none">Sign up →</a>
    </p>
  </div>
</section>
