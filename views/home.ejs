<div class="landing">

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-blob blob-1"></div>
    <div class="hero-blob-2 blob-2"></div>

    <div class="hero-badge">
      <span class="hero-badge-dot"></span>
      Track your subscriptions. Control your spending.
    </div>

    <h1>
      Stop paying for<br>
      <span class="hero-span">what you don't use</span>
    </h1>

    <p class="hero-sub">
      SubTracker gives you a clear picture of every subscription you pay for —
      organized by category, normalized by billing cycle, with upcoming renewal alerts.
    </p>

    <div class="hero-ctas">
      <% if (isAuthenticated) { %>
        <a href="/dashboard" class="btn-primary" style="font-size:15px;padding:10px 22px">
          <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
          Go to Dashboard
        </a>
        <a href="/subscriptions/new" class="btn-ghost" style="font-size:15px;padding:10px 22px">
          <i data-lucide="plus-circle" class="w-5 h-5"></i>
          Add Subscription
        </a>
      <% } else { %>
        <a href="/register" class="btn-primary" style="font-size:15px;padding:10px 22px">
          <i data-lucide="user-plus" class="w-5 h-5"></i>
          Get Started Free
        </a>
        <a href="/login" class="btn-ghost" style="font-size:15px;padding:10px 22px">
          <i data-lucide="log-in" class="w-5 h-5"></i>
          Sign In
        </a>
      <% } %>
    </div>

    <div class="hero-stats">
      <div>
        <div class="hero-stat-value">10+</div>
        <div class="hero-stat-label">Services Tracked</div>
      </div>
      <div style="width:1px;background:var(--border)"></div>
      <div>
        <div class="hero-stat-value">€/$</div>
        <div class="hero-stat-label">Multi-Currency</div>
      </div>
      <div style="width:1px;background:var(--border)"></div>
      <div>
        <div class="hero-stat-value">100%</div>
        <div class="hero-stat-label">Data Private</div>
      </div>
    </div>
  </section>

  <!-- ── Features ──────────────────────────────────────────────────────────── -->
  <section class="features-section">
    <div class="features-label">Features</div>
    <h2 class="features-title">Everything you need to<br><span class="hero-span">manage subscriptions</span></h2>
    <p class="features-sub">A complete toolkit to track, analyze, and optimize your monthly spend.</p>

    <div class="features-grid">
      <div class="feature-card" data-tilt>
        <div class="feature-icon">
          <i data-lucide="credit-card" class="w-6 h-6"></i>
        </div>
        <h3>Track Subscriptions</h3>
        <p>Keep all your subscriptions in one place. Netflix, Spotify, SaaS tools — organized by category with full billing history.</p>
      </div>

      <div class="feature-card" data-tilt>
        <div class="feature-icon">
          <i data-lucide="bar-chart-3" class="w-6 h-6"></i>
        </div>
        <h3>Analyze Spending</h3>
        <p>See your monthly and yearly totals at a glance. Normalize different billing cycles for a true picture of your costs.</p>
      </div>

      <div class="feature-card" data-tilt>
        <div class="feature-icon">
          <i data-lucide="bell" class="w-6 h-6"></i>
        </div>
        <h3>Renewal Alerts</h3>
        <p>Spot upcoming renewals before they hit. Identify subscriptions you rarely use and cut waste.</p>
      </div>
    </div>
  </section>

  <!-- ── How It Works ──────────────────────────────────────────────────────── -->
  <section class="how-section">
    <h2 class="how-title">How It Works</h2>
    <p class="how-sub">Get started in minutes. No credit card required.</p>

    <div class="how-grid">
      <div class="how-step">
        <div class="how-step-num">01</div>
        <h3>Add Your Subscriptions</h3>
        <p>Enter service name, cost, category and billing cycle. We handle the rest.</p>
      </div>
      <div class="how-step">
        <div class="how-step-num">02</div>
        <h3>Visualize Your Spend</h3>
        <p>See monthly and yearly totals with cost breakdowns by category.</p>
      </div>
      <div class="how-step">
        <div class="how-step-num">03</div>
        <h3>Save Money</h3>
        <p>Pause, cancel, or renegotiate subscriptions you no longer need.</p>
      </div>
    </div>

    <div class="how-cta">
      <% if (isAuthenticated) { %>
        <a href="/dashboard" class="btn-primary" style="font-size:15px;padding:10px 22px">
          <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
          Go to Dashboard
        </a>
      <% } else { %>
        <a href="/register" class="btn-primary" style="font-size:15px;padding:10px 22px">
          <i data-lucide="rocket" class="w-5 h-5"></i>
          Get Started Now
        </a>
      <% } %>
    </div>
  </section>

</div>
