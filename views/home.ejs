<!-- ── Hero Section ──────────────────────────────────────────────────────── -->
<section class="hero-bg relative overflow-hidden pt-24 pb-32 px-4">
  <!-- Decorative orbs -->
  <div class="absolute top-20 left-1/4 w-96 h-96 bg-purple-600/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute top-40 right-1/4 w-80 h-80 bg-blue-600/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass border border-purple-500/20 text-sm text-purple-300 font-medium mb-8">
      <i data-lucide="layers" class="w-4 h-4"></i>
      Track your subscriptions. Control your spending.
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-6">
      Sub<span class="gradient-text">Tracker</span>
    </h1>

    <!-- Subheadline -->
    <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Take control of your subscriptions. Analyze spending patterns.<br class="hidden sm:block" />
      Save money. Stop paying for what you don't use.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <% if (isAuthenticated) { %>
        <a href="/subscriptions" class="btn-gradient text-base px-8 py-3">
          <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
          View Dashboard
        </a>
        <a href="/subscriptions/new" class="btn-ghost text-base px-8 py-3">
          <i data-lucide="plus-circle" class="w-5 h-5"></i>
          Add Subscription
        </a>
      <% } else { %>
        <a href="/register" class="btn-gradient text-base px-8 py-3">
          <i data-lucide="user-plus" class="w-5 h-5"></i>
          Get Started Free
        </a>
        <a href="/login" class="btn-ghost text-base px-8 py-3">
          <i data-lucide="log-in" class="w-5 h-5"></i>
          Sign In
        </a>
      <% } %>
    </div>

    <!-- Social proof / stat pill -->
    <div class="mt-14 flex flex-wrap justify-center gap-8 text-center">
      <div>
        <p class="text-3xl font-bold gradient-text">10+</p>
        <p class="text-sm text-slate-500 mt-1">Services Tracked</p>
      </div>
      <div class="w-px bg-white/10 hidden sm:block"></div>
      <div>
        <p class="text-3xl font-bold gradient-text">€/$ Multi</p>
        <p class="text-sm text-slate-500 mt-1">Currency Support</p>
      </div>
      <div class="w-px bg-white/10 hidden sm:block"></div>
      <div>
        <p class="text-3xl font-bold gradient-text">100%</p>
        <p class="text-sm text-slate-500 mt-1">Data Private</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Features Section ──────────────────────────────────────────────────── -->
<section class="py-24 px-4">
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Everything you need to
        <span class="gradient-text"> manage subscriptions</span>
      </h2>
      <p class="text-slate-400 max-w-xl mx-auto">
        A complete toolkit to track, analyze and optimize your monthly subscription spend.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">

      <!-- Feature 1 -->
      <div class="glass glass-hover p-8 rounded-2xl">
        <div class="feature-icon-wrap mb-5">
          <i data-lucide="credit-card" class="w-6 h-6 text-purple-400"></i>
        </div>
        <h3 class="text-lg font-bold text-white mb-3">Track Subscriptions</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Keep all your subscriptions in one place. Netflix, Spotify, SaaS tools —
          organized by category with full billing history.
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="glass glass-hover p-8 rounded-2xl">
        <div class="feature-icon-wrap mb-5">
          <i data-lucide="bar-chart-3" class="w-6 h-6 text-blue-400"></i>
        </div>
        <h3 class="text-lg font-bold text-white mb-3">Analyze Spending</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          See your monthly and yearly totals at a glance. Normalize different billing
          cycles for a true picture of your spending.
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="glass glass-hover p-8 rounded-2xl">
        <div class="feature-icon-wrap mb-5">
          <i data-lucide="brain" class="w-6 h-6 text-pink-400"></i>
        </div>
        <h3 class="text-lg font-bold text-white mb-3">Smart Recommendations</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Identify subscriptions you rarely use, spot upcoming renewals, and get
          actionable suggestions to reduce waste.
        </p>
      </div>

    </div>
  </div>
</section>

<!-- ── How It Works ──────────────────────────────────────────────────────── -->
<section class="py-24 px-4 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-purple-950/10 to-transparent pointer-events-none"></div>
  <div class="max-w-4xl mx-auto relative">

    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">How It Works</h2>
      <p class="text-slate-400">Get started in minutes. No credit card required.</p>
    </div>

    <div class="grid sm:grid-cols-3 gap-8">
      <!-- Step 1 -->
      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-600/30 to-purple-600/10 border border-purple-500/20 flex items-center justify-center mx-auto mb-5">
          <i data-lucide="plus-circle" class="w-7 h-7 text-purple-400"></i>
        </div>
        <div class="text-xs font-bold text-purple-400 tracking-widest uppercase mb-2">Step 01</div>
        <h3 class="text-base font-semibold text-white mb-2">Add Your Subscriptions</h3>
        <p class="text-slate-500 text-sm">Enter your service name, cost, category and billing cycle.</p>
      </div>

      <!-- Step 2 -->
      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-600/30 to-blue-600/10 border border-blue-500/20 flex items-center justify-center mx-auto mb-5">
          <i data-lucide="pie-chart" class="w-7 h-7 text-blue-400"></i>
        </div>
        <div class="text-xs font-bold text-blue-400 tracking-widest uppercase mb-2">Step 02</div>
        <h3 class="text-base font-semibold text-white mb-2">Visualize Your Spend</h3>
        <p class="text-slate-500 text-sm">See monthly/yearly totals and cost breakdowns by category.</p>
      </div>

      <!-- Step 3 -->
      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-pink-600/30 to-pink-600/10 border border-pink-500/20 flex items-center justify-center mx-auto mb-5">
          <i data-lucide="trending-down" class="w-7 h-7 text-pink-400"></i>
        </div>
        <div class="text-xs font-bold text-pink-400 tracking-widest uppercase mb-2">Step 03</div>
        <h3 class="text-base font-semibold text-white mb-2">Save Money</h3>
        <p class="text-slate-500 text-sm">Pause, cancel or renegotiate subscriptions you no longer need.</p>
      </div>
    </div>

    <div class="text-center mt-14">
      <% if (isAuthenticated) { %>
        <a href="/subscriptions" class="btn-gradient text-base px-10 py-3">
          <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
          Go to Dashboard
        </a>
      <% } else { %>
        <a href="/register" class="btn-gradient text-base px-10 py-3">
          <i data-lucide="rocket" class="w-5 h-5"></i>
          Get Started Now
        </a>
      <% } %>
    </div>
  </div>
</section>
