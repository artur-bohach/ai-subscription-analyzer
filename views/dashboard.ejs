<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<% if (!hasSubscriptions) { %>
<!-- ── Empty State ──────────────────────────────────────────────────────────── -->
<div class="db-empty">
  <div class="db-empty-icon">
    <i data-lucide="wallet" class="w-10 h-10"></i>
  </div>
  <h2>No subscriptions yet</h2>
  <p>Add your first subscription to start tracking your spending, visualize costs by category, and take control of your budget.</p>
  <a href="/subscriptions/new" class="btn-primary" style="font-size:14px;padding:9px 20px">
    <i data-lucide="plus-circle" class="w-4 h-4"></i>
    Add your first subscription
  </a>
  <% if (totalSubs > 0) { %>
    <p class="db-empty-hint">You have <%= totalSubs %> inactive subscription(s). <a href="/subscriptions">View all →</a></p>
  <% } %>
</div>

<% } else { %>
<!-- ── Full Dashboard ───────────────────────────────────────────────────────── -->
<div class="db-wrap">

  <!-- Page header -->
  <div class="db-page-header">
    <div>
      <h1 class="db-page-title">Dashboard</h1>
      <p class="db-page-sub">Welcome back, <strong><%= currentUser.username %></strong></p>
    </div>
    <a href="/subscriptions/new" class="btn-primary" style="font-size:13px;padding:8px 16px">
      <i data-lucide="plus" class="w-4 h-4"></i> Add Subscription
    </a>
  </div>

  <!-- ── Stat Cards ──────────────────────────────────────────────────────────── -->
  <div class="db-stat-grid">

    <div class="db-stat-card" data-tilt>
      <div class="db-stat-icon">
        <i data-lucide="wallet" class="w-5 h-5"></i>
      </div>
      <div class="db-stat-label">Monthly Spending</div>
      <div class="db-stat-value">
        €<span data-countup data-target="<%= stats.monthlyTotal.toFixed(2) %>" data-decimals="2"><%= stats.monthlyTotal.toFixed(2) %></span>
      </div>
      <div class="db-stat-sub"><%= stats.activeCount %> active subscriptions</div>
    </div>

    <div class="db-stat-card" data-tilt>
      <div class="db-stat-icon">
        <i data-lucide="calendar" class="w-5 h-5"></i>
      </div>
      <div class="db-stat-label">Yearly Projection</div>
      <div class="db-stat-value">
        €<span data-countup data-target="<%= stats.yearlyTotal.toFixed(2) %>" data-decimals="2"><%= stats.yearlyTotal.toFixed(2) %></span>
      </div>
      <div class="db-stat-sub">based on current plan</div>
    </div>

    <div class="db-stat-card" data-tilt>
      <div class="db-stat-icon" style="color:var(--neon)">
        <i data-lucide="credit-card" class="w-5 h-5"></i>
      </div>
      <div class="db-stat-label">Active Plans</div>
      <div class="db-stat-value" style="color:var(--neon)">
        <span data-countup data-target="<%= stats.activeCount %>"><%= stats.activeCount %></span>
      </div>
      <div class="db-stat-sub">running subscriptions</div>
    </div>

    <div class="db-stat-card" data-tilt>
      <div class="db-stat-icon" style="color:var(--warn)">
        <i data-lucide="piggy-bank" class="w-5 h-5"></i>
      </div>
      <div class="db-stat-label">Potential Savings</div>
      <div class="db-stat-value" style="color:var(--warn)">
        €<span data-countup data-target="<%= stats.potentialSavings.toFixed(2) %>" data-decimals="2"><%= stats.potentialSavings.toFixed(2) %></span>
      </div>
      <div class="db-stat-sub">by cancelling unused</div>
    </div>
  </div>

  <!-- ── Charts Row ─────────────────────────────────────────────────────────── -->
  <div class="db-charts-row">

    <!-- Doughnut -->
    <div class="db-chart-card">
      <div class="db-chart-header">
        <h2 class="db-chart-title">Spending by Category</h2>
        <span class="db-chart-meta">monthly</span>
      </div>
      <div class="db-donut-wrap">
        <div class="db-donut-canvas-wrap">
          <canvas id="doughnutChart"></canvas>
          <div class="db-donut-center">
            <p class="db-donut-label">Total</p>
            <p class="db-donut-value">€<%= stats.monthlyTotal.toFixed(2) %></p>
          </div>
        </div>
        <div class="db-legend">
          <% categoryChartData.labels.forEach((label, i) => { %>
            <div class="db-legend-item">
              <span class="db-legend-dot" style="background:<%= categoryChartData.colors[i] %>"></span>
              <span class="db-legend-name"><%= label %></span>
              <span class="db-legend-val">€<%= categoryChartData.amounts[i].toFixed(2) %></span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Horizontal Bar -->
    <div class="db-chart-card">
      <div class="db-chart-header">
        <h2 class="db-chart-title">Cost per Subscription</h2>
        <span class="db-chart-meta">monthly equiv.</span>
      </div>
      <div class="db-chart-body">
        <div style="position:relative;height:<%= Math.max(180, barChartData.labels.length * 36) %>px">
          <canvas id="barChart"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Line Chart ─────────────────────────────────────────────────────────── -->
  <div class="db-chart-card">
    <div class="db-chart-header">
      <h2 class="db-chart-title">Spending Over Time</h2>
      <span class="db-chart-meta">last 6 months</span>
    </div>
    <div class="db-chart-body">
      <div style="position:relative;height:200px">
        <canvas id="lineChart"></canvas>
      </div>
    </div>
  </div>

  <!-- ── Upcoming + Breakdown ───────────────────────────────────────────────── -->
  <div class="db-bottom-row">

    <!-- Upcoming Payments -->
    <div class="db-chart-card">
      <div class="db-chart-header">
        <h2 class="db-chart-title">Upcoming Payments</h2>
        <span class="db-chart-meta">next 8 renewals</span>
      </div>
      <div class="db-upcoming-list">
        <% upcomingPayments.forEach(p => { %>
          <div class="db-upcoming-item <%= p.urgent ? 'db-upcoming-urgent' : '' %>">
            <div class="db-upcoming-icon">
              <i data-lucide="<%= p.icon %>" class="w-3.5 h-3.5"></i>
            </div>
            <div class="db-upcoming-info">
              <p class="db-upcoming-name"><%= p.name %></p>
              <p class="db-upcoming-date <%= p.urgent ? 'urgent' : '' %>">
                <%= p.urgent ? '⚠ ' : '' %><%= p.nextDate %>
                <% if (p.daysUntil === 0) { %>(today)
                <% } else if (p.daysUntil === 1) { %>(tomorrow)
                <% } else if (p.daysUntil <= 3) { %>(in <%= p.daysUntil %> days)
                <% } %>
              </p>
            </div>
            <p class="db-upcoming-cost"><%= p.cost %></p>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- Breakdown -->
    <div class="db-chart-card">
      <div class="db-chart-header">
        <h2 class="db-chart-title">Subscription Breakdown</h2>
        <span class="db-chart-meta">by monthly cost</span>
      </div>
      <div class="db-breakdown-list">
        <% breakdown.forEach(item => { %>
          <div class="db-breakdown-item">
            <div class="db-breakdown-top">
              <span class="db-breakdown-name"><%= item.name %></span>
              <div class="db-breakdown-right">
                <span class="db-breakdown-pct"><%= item.pct %>%</span>
                <span class="db-breakdown-val">€<%= item.monthly.toFixed(2) %></span>
              </div>
            </div>
            <div class="db-progress-track">
              <div class="db-progress-fill" style="width:<%= item.pct %>%;background:<%= item.color %>"></div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- ── Quick Actions ──────────────────────────────────────────────────────── -->
  <div class="db-chart-card" style="padding:20px 24px">
    <h2 class="db-chart-title" style="margin-bottom:14px">Quick Actions</h2>
    <div style="display:flex;flex-wrap:wrap;gap:10px">
      <a href="/subscriptions/new" class="btn-primary" style="font-size:13px;padding:8px 16px">
        <i data-lucide="plus-circle" class="w-4 h-4"></i> Add Subscription
      </a>
      <a href="/subscriptions" class="btn-ghost" style="font-size:13px;padding:8px 16px">
        <i data-lucide="list" class="w-4 h-4"></i> View All
      </a>
      <button class="btn-ghost" style="font-size:13px;padding:8px 16px;opacity:0.4;cursor:not-allowed" disabled>
        <i data-lucide="brain" class="w-4 h-4"></i> AI Recommendations
      </button>
      <button class="btn-ghost" style="font-size:13px;padding:8px 16px;opacity:0.4;cursor:not-allowed" disabled>
        <i data-lucide="download" class="w-4 h-4"></i> Export Report
      </button>
    </div>
  </div>

</div><!-- /db-wrap -->
<% } %>

<!-- ── Chart.js Init ───────────────────────────────────────────────────────── -->
<% if (hasSubscriptions) { %>
<script>
(function () {
  'use strict';

  const catData  = <%- JSON.stringify(categoryChartData) %>;
  const barData  = <%- JSON.stringify(barChartData) %>;
  const lineData = <%- JSON.stringify(lineChartData) %>;

  const neon    = '#00FF87';
  const muted   = '#555555';
  const gridCol = 'rgba(255,255,255,0.04)';

  Chart.defaults.color = '#888888';
  Chart.defaults.font.family = "'Inter', system-ui, sans-serif";
  Chart.defaults.font.size   = 12;

  // ── Doughnut ──────────────────────────────────────────────────────────────
  new Chart(document.getElementById('doughnutChart'), {
    type: 'doughnut',
    data: {
      labels:   catData.labels,
      datasets: [{
        data:            catData.amounts,
        backgroundColor: catData.colors.map(c => c + 'cc'),
        borderColor:     catData.colors,
        borderWidth:     2,
        hoverOffset:     6,
      }]
    },
    options: {
      cutout: '70%',
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => {
              const pct = ((ctx.parsed / catData.total) * 100).toFixed(1);
              return `  €${ctx.parsed.toFixed(2)} (${pct}%)`;
            }
          }
        }
      }
    }
  });

  // ── Horizontal Bar ────────────────────────────────────────────────────────
  new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
      labels:   barData.labels,
      datasets: [{
        data:            barData.amounts,
        backgroundColor: 'rgba(255,255,255,0.08)',
        borderColor:     'rgba(255,255,255,0.2)',
        borderWidth:     1,
        borderRadius:    4,
        barThickness:    18,
        hoverBackgroundColor: neon + '33',
        hoverBorderColor: neon,
      }]
    },
    options: {
      indexAxis: 'y',
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => `  €${ctx.parsed.x.toFixed(2)}/mo`
          }
        }
      },
      scales: {
        x: { grid: { color: gridCol }, ticks: { callback: v => `€${v}` } },
        y: { grid: { display: false }, ticks: { font: { size: 11 } } }
      }
    }
  });

  // ── Line Chart ─────────────────────────────────────────────────────────────
  const lineCtx = document.getElementById('lineChart');
  const grad = lineCtx.getContext('2d').createLinearGradient(0, 0, 0, 200);
  grad.addColorStop(0, 'rgba(0,255,135,0.2)');
  grad.addColorStop(1, 'rgba(0,255,135,0.00)');

  new Chart(lineCtx, {
    type: 'line',
    data: {
      labels:   lineData.labels,
      datasets: [{
        data:             lineData.amounts,
        borderColor:      neon,
        backgroundColor:  grad,
        borderWidth:      2,
        pointRadius:      4,
        pointHoverRadius: 6,
        pointBackgroundColor: neon,
        pointBorderColor:    '#000',
        pointBorderWidth:    2,
        fill:    true,
        tension: 0.4,
      }]
    },
    options: {
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: { label: ctx => `  €${ctx.parsed.y.toFixed(2)}/mo` }
        }
      },
      scales: {
        x: { grid: { color: gridCol } },
        y: { grid: { color: gridCol }, ticks: { callback: v => `€${v}` }, beginAtZero: true }
      }
    }
  });
})();
</script>
<% } %>
