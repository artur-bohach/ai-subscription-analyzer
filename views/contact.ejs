<!-- ── Contact Header ─────────────────────────────────────────────────────── -->
<section class="pt-16 pb-8 px-4">
  <div class="max-w-2xl mx-auto text-center">
    <div style="display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:20px;background:var(--card);border:1px solid var(--border2);font-size:13px;color:var(--muted);font-weight:500;margin-bottom:24px;">
      <i data-lucide="mail" class="w-4 h-4" style="color:var(--neon);"></i>
      Get In Touch
    </div>
    <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">
      Contact <span style="color:var(--neon);">Us</span>
    </h1>
    <p style="color:var(--muted);font-size:18px;">
      Have a question or feedback? We'd love to hear from you.
    </p>
  </div>
</section>

<!-- ── Contact Form ───────────────────────────────────────────────────────── -->
<section class="py-12 px-4">
  <div class="max-w-2xl mx-auto">
    <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-card);padding:32px;">

      <!-- ── The Form (UI only — validated client-side, no server submit) ── -->
      <form id="contact-form" novalidate autocomplete="off">

        <div class="grid sm:grid-cols-2 gap-5 mb-5">

          <!-- Name -->
          <div>
            <label for="contact-name" class="form-label">
              Full Name <span style="color:var(--danger);">*</span>
            </label>
            <input
              id="contact-name"
              name="name"
              type="text"
              class="form-input"
              placeholder="John Doe"
              autocomplete="name"
              minlength="2"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="contact-email" class="form-label">
              Email Address <span style="color:var(--danger);">*</span>
            </label>
            <input
              id="contact-email"
              name="email"
              type="email"
              class="form-input"
              placeholder="you@example.com"
              autocomplete="email"
            />
          </div>
        </div>

        <!-- Subject -->
        <div class="mb-5">
          <label for="contact-subject" class="form-label">
            Subject <span style="color:var(--danger);">*</span>
          </label>
          <input
            id="contact-subject"
            name="subject"
            type="text"
            class="form-input"
            placeholder="e.g. Bug report, Feature idea, General question…"
            minlength="3"
          />
        </div>

        <!-- Message with character counter injected by JS -->
        <div class="mb-6">
          <label for="contact-message" class="form-label">
            Message <span style="color:var(--danger);">*</span>
            <span style="color:var(--muted2);font-weight:400;">(min 10 characters)</span>
          </label>
          <textarea
            id="contact-message"
            name="message"
            rows="5"
            class="form-input resize-none"
            placeholder="Write your message here…"
          ></textarea>
        </div>

        <button type="submit" class="btn-primary w-full justify-center" style="font-size:15px;padding:11px;">
          <i data-lucide="send" class="w-5 h-5"></i>
          Send Message
        </button>
      </form>

      <!-- ── Animated Success Screen (hidden; shown by JS after valid submit) -->
      <div id="contact-success" class="contact-success-wrapper">

        <!-- Animated SVG checkmark -->
        <svg class="checkmark-svg" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle class="ck-bg" cx="36" cy="36" r="34"/>
          <circle class="ck-ring" cx="36" cy="36" r="33"/>
          <path class="ck-check" d="M20 36 L30 46 L52 24"/>
        </svg>

        <div>
          <h3 class="text-2xl font-bold text-white mb-2">Message Sent!</h3>
          <p style="color:var(--muted);font-size:14px;max-width:280px;margin:0 auto;line-height:1.6;">
            Thank you for reaching out. We'll get back to you as soon as possible.
          </p>
        </div>

        <div class="flex flex-wrap justify-center gap-2 text-xs">
          <span style="padding:4px 12px;border-radius:20px;background:rgba(0,255,135,0.08);border:1px solid rgba(0,255,135,0.2);color:var(--neon);">
            <i data-lucide="check" class="w-3 h-3 inline-block mr-1"></i>Received
          </span>
          <span style="padding:4px 12px;border-radius:20px;background:rgba(255,184,0,0.08);border:1px solid rgba(255,184,0,0.2);color:var(--warn);">
            <i data-lucide="clock" class="w-3 h-3 inline-block mr-1"></i>Reply within 24h
          </span>
        </div>

        <button
          type="button"
          onclick="window.resetContactForm()"
          class="btn-ghost text-sm mt-1"
        >
          <i data-lucide="rotate-ccw" class="w-4 h-4"></i>
          Send another message
        </button>
      </div>

    </div>

    <!-- ── Info Cards ─────────────────────────────────────────────────────── -->
    <div class="grid sm:grid-cols-3 gap-4 mt-8">
      <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-card);padding:20px;text-align:center;">
        <i data-lucide="github" style="width:24px;height:24px;color:var(--muted);margin:0 auto 8px;display:block;"></i>
        <p style="font-size:14px;font-weight:500;color:var(--text);">GitHub</p>
        <p style="font-size:12px;color:var(--muted2);margin-top:4px;">Open an issue</p>
      </div>
      <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-card);padding:20px;text-align:center;">
        <i data-lucide="book-open" style="width:24px;height:24px;color:var(--neon);margin:0 auto 8px;display:block;"></i>
        <p style="font-size:14px;font-weight:500;color:var(--text);">Docs</p>
        <p style="font-size:12px;color:var(--muted2);margin-top:4px;">Read the README</p>
      </div>
      <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-card);padding:20px;text-align:center;">
        <i data-lucide="zap" style="width:24px;height:24px;color:var(--warn);margin:0 auto 8px;display:block;"></i>
        <p style="font-size:14px;font-weight:500;color:var(--text);">Quick Start</p>
        <p style="font-size:12px;color:var(--muted2);margin-top:4px;">Get up in minutes</p>
      </div>
    </div>

  </div>
</section>
