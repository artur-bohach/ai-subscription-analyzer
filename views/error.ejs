<!-- ── Error Page ─────────────────────────────────────────────────────────── -->
<section class="min-h-[calc(100vh-8rem)] flex items-center justify-center px-4">
  <div class="text-center max-w-lg mx-auto">

    <!-- Error Code -->
    <div class="text-9xl font-black gradient-text leading-none mb-6 select-none">
      <%= statusCode || 500 %>
    </div>

    <!-- Decorative icon -->
    <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-purple-600/20 to-blue-600/20 border border-white/10 flex items-center justify-center mx-auto mb-6">
      <% if (statusCode === 404) { %>
        <i data-lucide="search-x" class="w-10 h-10 text-purple-400"></i>
      <% } else { %>
        <i data-lucide="alert-triangle" class="w-10 h-10 text-amber-400"></i>
      <% } %>
    </div>

    <h1 class="text-2xl font-bold text-white mb-3">
      <%= statusCode === 404 ? 'Page Not Found' : 'Something Went Wrong' %>
    </h1>

    <p class="text-slate-400 mb-8 leading-relaxed">
      <%= message || "An unexpected error occurred. Please try again later." %>
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="btn-gradient px-8 py-2.5">
        <i data-lucide="home" class="w-4 h-4"></i>
        Go Home
      </a>
      <a href="/subscriptions" class="btn-ghost px-8 py-2.5">
        <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
        Dashboard
      </a>
    </div>
  </div>
</section>
