<!-- ── Error Page ─────────────────────────────────────────────────────────── -->
<section class="min-h-[calc(100vh-8rem)] flex items-center justify-center px-4">
  <div class="text-center max-w-lg mx-auto">

    <!-- Error Code -->
    <div style="font-size:clamp(6rem,15vw,9rem);font-weight:900;line-height:1;color:var(--neon);margin-bottom:24px;user-select:none;">
      <%= statusCode || 500 %>
    </div>

    <!-- Decorative icon -->
    <div style="width:80px;height:80px;border-radius:16px;background:rgba(0,255,135,0.08);border:1px solid rgba(0,255,135,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
      <% if (statusCode === 404) { %>
        <i data-lucide="search-x" style="width:40px;height:40px;color:var(--neon);"></i>
      <% } else { %>
        <i data-lucide="alert-triangle" style="width:40px;height:40px;color:var(--warn);"></i>
      <% } %>
    </div>

    <h1 class="text-2xl font-bold text-white mb-3">
      <%= statusCode === 404 ? 'Page Not Found' : 'Something Went Wrong' %>
    </h1>

    <p style="color:var(--muted);margin-bottom:32px;line-height:1.6;">
      <%= message || "An unexpected error occurred. Please try again later." %>
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="btn-primary" style="padding:10px 32px;">
        <i data-lucide="home" class="w-4 h-4"></i>
        Go Home
      </a>
      <a href="/subscriptions" class="btn-ghost" style="padding:10px 32px;">
        <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
        Dashboard
      </a>
    </div>
  </div>
</section>
